{
  "version": 8,
  "name": "Loom Sovereign Basemap (Natural Earth)",
  "metadata": {
    "loom:source": "Natural Earth (public domain) via tippecanoe"
  },
  "sources": {
    "basemap": {
      "type": "vector",
      "url": "mbtiles://{basemap}"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#0b1021"
      }
    },
    {
      "id": "ocean",
      "type": "fill",
      "source": "basemap",
      "source-layer": "ocean",
      "paint": {
        "fill-color": "#0d1b3e"
      }
    },
    {
      "id": "land",
      "type": "fill",
      "source": "basemap",
      "source-layer": "land",
      "paint": {
        "fill-color": "#1b2350"
      }
    },
    {
      "id": "countries-fill",
      "type": "fill",
      "source": "basemap",
      "source-layer": "countries",
      "paint": {
        "fill-color": "#232c63",
        "fill-opacity": 0.35
      }
    },
    {
      "id": "boundaries",
      "type": "line",
      "source": "basemap",
      "source-layer": "boundaries",
      "paint": {
        "line-color": "#5a6bb5",
        "line-width": 0.6
      }
    },
    {
      "id": "states",
      "type": "line",
      "source": "basemap",
      "source-layer": "states",
      "minzoom": 3,
      "paint": {
        "line-color": "#3d4a8a",
        "line-width": 0.4,
        "line-dasharray": [
          2,
          2
        ]
      }
    }
  ]
}
