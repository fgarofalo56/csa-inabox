# loom-maps-tileserver front — serves the maplibre-gl assets + a root /style.json
# and reverse-proxies tiles/glyphs/sprites/data to tileserver-gl on :8081.
{
	admin off
	auto_https off
}
:8080 {
	# maplibre-gl runtime assets (the Console loads these from the same in-VNet origin).
	handle /maplibre-gl.js {
		root * /assets
		file_server
	}
	handle /maplibre-gl.css {
		root * /assets
		file_server
	}
	# The Console proxy fetches LOOM_MAPS_TILE_URL = <base>/style.json; map it to the loom style.
	handle /style.json {
		rewrite * /styles/loom/style.json
		reverse_proxy localhost:8081
	}
	# Everything else (/data, /fonts, /styles, /sprites, TileJSON, tiles) → tileserver-gl.
	handle {
		reverse_proxy localhost:8081
	}
}
