{
  "name": "${MIRROR_ID}-mysql",
  "config": {
    "connector.class": "io.debezium.connector.mysql.MySqlConnector",
    "tasks.max": "1",

    "database.hostname": "${MYSQL_HOST}",
    "database.port": "3306",
    "database.user": "${MYSQL_USER}",
    "database.password": "${MYSQL_PASSWORD_KV_REF}",
    "database.server.id": "${MYSQL_SERVER_ID}",
    "database.include.list": "${MYSQL_DATABASE}",

    "topic.prefix": "csa-loom-mirror.${MIRROR_ID}",
    "table.include.list": "${TABLE_INCLUDE_LIST}",

    "schema.history.internal.kafka.bootstrap.servers": "${EVENTHUBS_BOOTSTRAP}",
    "schema.history.internal.kafka.topic": "csa-loom-schema-history.${MIRROR_ID}",

    "include.schema.changes": "true",
    "decimal.handling.mode": "double",
    "time.precision.mode": "adaptive_time_microseconds",

    "transforms": "unwrap",
    "transforms.unwrap.type": "io.debezium.transforms.ExtractNewRecordState",
    "transforms.unwrap.drop.tombstones": "false",
    "transforms.unwrap.delete.handling.mode": "rewrite",
    "transforms.unwrap.add.fields": "op,ts_ms,source.schema,source.table,source.file,source.pos"
  }
}
