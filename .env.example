# ─────────────────────────────────────────────────────────────
# CSA-in-a-Box Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────

# Portal / Docker Compose
ENVIRONMENT=local
# Default to enforcing Entra ID auth so the portal is secure-by-default.
# Set to "true" only for local development against a freshly-cloned repo where
# you have not yet wired up an app registration. Production containers must
# leave this as "false" or unset.
AUTH_DISABLED=false
# Auth mode: "spa" (default, MSAL in browser) or "bff" (backend-for-frontend).
AUTH_MODE=spa
# Redis password — required by docker-compose.yml; generate a random string.
REDIS_PASSWORD=change-me-to-a-strong-random-value

# Azure Authentication
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_SUBSCRIPTION_ID=your-subscription-id

# Azure Government (uncomment for Gov deployment)
# AZURE_ENVIRONMENT=AzureUSGovernment
# AZURE_AUTHORITY_HOST=https://login.microsoftonline.us

# Data Lake Storage
ADLS_ACCOUNT_NAME=your-storage-account
ADLS_ACCOUNT_KEY=your-storage-key

# Databricks
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your-pat-token

# Event Hub (for streaming)
EVENTHUB_CONNECTION_STRING=your-connection-string
EVENTHUB_NAME=telemetry

# Teams Webhook (for alerts)
TEAMS_WEBHOOK_URL=https://your-webhook-url

# API Keys (for open data fetchers)
NASS_API_KEY=your-nass-key
CENSUS_API_KEY=your-census-key
NOAA_API_TOKEN=your-noaa-token
EPA_API_KEY=your-epa-key

# Synapse Analytics
SYNAPSE_SQL_ENDPOINT=your-synapse-workspace.sql.azuresynapse.net
SYNAPSE_DEV_ENDPOINT=https://your-synapse-workspace.dev.azuresynapse.net

# Microsoft Purview
PURVIEW_ACCOUNT_NAME=your-purview-account
PURVIEW_ENDPOINT=https://your-purview-account.purview.azure.com

# Log Analytics
LOG_ANALYTICS_WORKSPACE_ID=your-workspace-id
LOG_ANALYTICS_WORKSPACE_KEY=your-workspace-key

# Cosmos DB (metadata store)
COSMOS_DB_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
COSMOS_DB_KEY=your-cosmos-key
COSMOS_DB_DATABASE=csa-metadata

# Terraform Backend (uncomment for TF deployments)
# TF_BACKEND_RESOURCE_GROUP=rg-terraform-state
# TF_BACKEND_STORAGE_ACCOUNT=stterraformstate
# TF_BACKEND_CONTAINER=tfstate
# TF_BACKEND_KEY=csa-inabox.tfstate
