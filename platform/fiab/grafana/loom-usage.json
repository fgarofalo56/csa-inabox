{
  "uid": "loom-usage",
  "title": "CSA Loom — Usage",
  "tags": ["csa-loom", "usage", "f21"],
  "schemaVersion": 39,
  "version": 0,
  "editable": true,
  "timezone": "",
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "5m",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Console requests / sec (loom-console)",
      "description": "Azure Container App ingress request volume for the loom-console app — overall platform usage.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "azure-monitor-oob" },
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "azure-monitor-oob" },
          "azureMonitor": {
            "resources": [
              {
                "subscription": "e093f4fd-5047-4ee4-968d-a56942c665f3",
                "resourceGroup": "rg-csa-loom-admin-centralus",
                "metricNamespace": "microsoft.app/containerapps",
                "resourceName": "loom-console"
              }
            ],
            "metricNamespace": "microsoft.app/containerapps",
            "metricName": "Requests",
            "aggregation": "Total",
            "timeGrain": "auto"
          }
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Active replicas",
      "description": "loom-console replica count over time — scale activity tracks active usage.",
