    {
      "id": 4,
      "type": "timeseries",
      "title": "Console request volume by status (Log Analytics)",
      "description": "loom-console ingress requests grouped by HTTP status from ContainerAppSystemLogs / console logs — usage and error trend.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "azure-monitor-oob" },
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Log Analytics",
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "azure-monitor-oob" },
          "azureLogAnalytics": {
            "resources": ["/subscriptions/e093f4fd-5047-4ee4-968d-a56942c665f3/resourceGroups/rg-csa-loom-admin-centralus/providers/Microsoft.OperationalInsights/workspaces/law-csa-loom-centralus"],
            "query": "ContainerAppConsoleLogs_CL | where ContainerName_s == 'loom-console' | summarize Entries=count() by bin(TimeGenerated, 1h) | order by TimeGenerated asc"
