{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Generated Pipeline Definition Schema",
  "description": "JSON Schema for ADF pipelines generated by the metadata-driven framework",
  "type": "object",
  "required": [
    "pipeline_id",
    "pipeline_name",
    "source_id",
    "template_type",
    "parameters",
    "activities",
    "triggers",
    "monitoring"
  ],
  "properties": {
    "pipeline_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the generated pipeline"
    },
    "pipeline_name": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]+$",
      "minLength": 1,
      "maxLength": 260,
      "description": "Name of the ADF pipeline"
    },
    "source_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the source registration that generated this pipeline"
    },
    "template_type": {
      "type": "string",
      "enum": [
        "adf_batch_copy",
        "adf_incremental",
        "adf_cdc",
        "adf_api_ingestion",
        "adf_streaming"
      ],
      "description": "Template used to generate this pipeline"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "default": "1.0.0",
      "description": "Semantic version of the pipeline definition"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when pipeline was generated"
    },
    "parameters": {
      "type": "object",
      "description": "Pipeline parameters",
      "properties": {
        "source_connection": {
          "type": "object",
          "description": "Source connection parameters"
        },
        "sink_connection": {
          "type": "object",
          "description": "Destination storage parameters"
        },
        "batch_size": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000,
          "default": 10000
        },
        "parallelization": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32,
          "default": 4
        },
        "timeout_minutes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2880,
          "default": 60
        },
        "retry_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10,
          "default": 3
        }
      }
    },
    "activities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Activity name"
          },
          "type": {
            "type": "string",
            "enum": [
              "Copy",
              "Lookup",
              "GetMetadata",
              "Script",
              "StoredProcedure",
              "WebActivity",
              "Wait",
              "ExecutePipeline",
              "IfCondition",
              "ForEach",
              "Until"
            ],
            "description": "ADF activity type"
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "activity": {
                  "type": "string"
                },
                "dependency_conditions": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": ["Succeeded", "Failed", "Skipped", "Completed"]
                  }
                }
              }
            }
          },
          "configuration": {
            "type": "object",
            "description": "Activity-specific configuration"
          }
        }
      }
    },
    "datasets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Dataset name"
          },
          "type": {
            "type": "string",
            "description": "Dataset type (e.g., AzureSqlTable, DelimitedText, Json)"
          },
          "linked_service": {
            "type": "string",
            "description": "Reference to linked service"
          },
          "schema": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                }
              }
            }
          },
          "parameters": {
            "type": "object",
            "description": "Dataset parameters"
          }
        }
      }
    },
    "linked_services": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Linked service name"
          },
          "type": {
            "type": "string",
            "description": "Linked service type"
          },
          "connection_string": {
            "type": "object",
            "description": "Connection configuration"
          },
          "parameters": {
            "type": "object",
            "description": "Linked service parameters"
          }
        }
      }
    },
    "triggers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Trigger name"
          },
          "type": {
            "type": "string",
            "enum": [
              "ScheduleTrigger",
              "TumblingWindowTrigger",
              "BlobEventsTrigger",
              "CustomEventsTrigger"
            ],
            "description": "Trigger type"
          },
          "configuration": {
            "type": "object",
            "description": "Trigger-specific configuration"
          },
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "Whether trigger is enabled"
          }
        }
      }
    },
    "monitoring": {
      "type": "object",
      "required": ["alerts"],
      "properties": {
        "alerts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "condition", "action"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Alert name"
              },
              "condition": {
                "type": "object",
                "properties": {
                  "metric": {
                    "type": "string",
                    "enum": [
                      "PipelineSucceededRuns",
                      "PipelineFailedRuns",
                      "ActivitySucceededRuns",
                      "ActivityFailedRuns",
                      "TriggerSucceededRuns",
                      "TriggerFailedRuns"
                    ]
                  },
                  "aggregation": {
                    "type": "string",
                    "enum": ["Total", "Count", "Average", "Maximum", "Minimum"]
                  },
                  "operator": {
                    "type": "string",
                    "enum": ["GreaterThan", "LessThan", "GreaterThanOrEqual", "LessThanOrEqual"]
                  },
                  "threshold": {
                    "type": "number"
                  },
                  "time_window": {
                    "type": "string",
                    "pattern": "^PT\\d+[MH]$",
                    "description": "Time window in ISO 8601 duration format"
                  }
                }
              },
              "action": {
                "type": "object",
                "properties": {
                  "action_group": {
                    "type": "string",
                    "description": "Azure Monitor action group"
                  },
                  "severity": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 4,
                    "description": "Alert severity (0=Critical, 4=Verbose)"
                  }
                }
              }
            }
          }
        },
        "metrics": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "aggregation": {
                "type": "string",
                "enum": ["Total", "Count", "Average", "Maximum", "Minimum"]
              },
              "dimension_filters": {
                "type": "object",
                "description": "Dimension filters for the metric"
              }
            }
          }
        }
      }
    },
    "data_quality": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Whether data quality checks are enabled"
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Quality rule name"
              },
              "type": {
                "type": "string",
                "enum": ["not_null", "unique", "range", "pattern", "custom"],
                "description": "Type of quality rule"
              },
              "column": {
                "type": "string",
                "description": "Column to validate (for column-level rules)"
              },
              "parameters": {
                "type": "object",
                "description": "Rule-specific parameters"
              },
              "severity": {
                "type": "string",
                "enum": ["warning", "error", "critical"],
                "default": "error"
              },
              "on_failure": {
                "type": "string",
                "enum": ["continue", "stop", "quarantine"],
                "default": "continue",
                "description": "Action to take when rule fails"
              }
            }
          }
        },
        "quarantine_dataset": {
          "type": "string",
          "description": "Dataset for quarantined records"
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "description": {
          "type": "string",
          "maxLength": 1000,
          "description": "Pipeline description"
        },
        "tags": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Resource tags"
        },
        "annotations": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Pipeline annotations"
        },
        "documentation_url": {
          "type": "string",
          "format": "uri",
          "description": "URL to pipeline documentation"
        }
      }
    },
    "deployment": {
      "type": "object",
      "properties": {
        "resource_group": {
          "type": "string",
          "description": "Target resource group"
        },
        "data_factory": {
          "type": "string",
          "description": "Target data factory name"
        },
        "integration_runtime": {
          "type": "string",
          "description": "Integration runtime to use"
        },
        "environment": {
          "type": "string",
          "enum": ["development", "staging", "production"],
          "description": "Target environment"
        },
        "arm_template_path": {
          "type": "string",
          "description": "Path to generated ARM template"
        },
        "bicep_template_path": {
          "type": "string",
          "description": "Path to generated Bicep template"
        },
        "parameters_file_path": {
          "type": "string",
          "description": "Path to deployment parameters file"
        }
      }
    },
    "lineage": {
      "type": "object",
      "properties": {
        "source_systems": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "tables": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "target_datasets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "format": {
                "type": "string"
              }
            }
          }
        },
        "transformations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": ["copy", "mapping", "aggregation", "filter", "join", "custom"]
              },
              "description": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}