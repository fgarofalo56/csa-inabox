model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

	annotation PBI_QueryOrder = ["Maturity Assessment", "Adoption Signals"]

ref table 'Maturity Assessment'
ref table 'Adoption Signals'
ref cultureInfo en-US
