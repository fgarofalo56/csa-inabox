{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://csa-loom/docs/fiab/org-visuals/coe-library/catalog.schema.json",
  "title": "CoE template-library catalog",
  "description": "Index of the default Cloud Center of Excellence (CoE) Power BI report templates the Organizational Visuals feature reads to present the library.",
  "type": "object",
  "required": ["version", "templates"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string" },
    "generator": { "type": "string" },
    "description": { "type": "string" },
    "templates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "category", "thumbnail", "pbipPath", "dataSources", "requiredRoles"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "category": { "type": "string" },
          "kind": { "type": "string" },
          "thumbnail": { "type": "string" },
          "pbipPath": { "type": "string" },
          "reportPath": { "type": "string" },
          "semanticModelPath": { "type": "string" },
          "pages": { "type": "array", "items": { "type": "string" } },
          "measures": { "type": "integer" },
          "dataSources": { "type": "array", "items": { "type": "string" } },
          "requiredRoles": { "type": "array", "items": { "type": "string" } },
          "parameters": { "type": "array", "items": { "type": "string" } },
          "sampleData": { "type": "boolean" }
        }
      }
    }
  }
}
