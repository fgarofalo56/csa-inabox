					//     Resp = Json.Document(Web.Contents(Url, [Headers=[#"Content-Type"="application/json"], Content=Json.FromValue(Q)])),
					//     T = Resp[tables]{0},
					//     Rows = Table.FromRows(T[rows], List.Transform(T[columns], each [name]))
					// in
					//     Rows
					// === end live source ===
					Source = #table(
						type table [#"ServiceName"=type text, #"Day"=type datetime, #"UptimePct"=type number, #"SlaTarget"=type number],
						{
							{"API Gateway", #datetime(2026,3,10,0,0,0), 0.9995, 0.999},
							{"API Gateway", #datetime(2026,3,11,0,0,0), 0.9988, 0.999},
							{"AKS prod", #datetime(2026,3,10,0,0,0), 0.9999, 0.995},
