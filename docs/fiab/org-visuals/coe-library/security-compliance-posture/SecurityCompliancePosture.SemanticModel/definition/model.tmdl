model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

	annotation PBI_QueryOrder = ["Secure Score", "Policy Compliance"]

ref table 'Secure Score'
ref table 'Policy Compliance'
ref cultureInfo en-US
