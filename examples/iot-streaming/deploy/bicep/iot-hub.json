{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.40.2.10011",
      "templateHash": "16846370445509816126"
    }
  },
  "parameters": {
    "baseName": {
      "type": "string",
      "defaultValue": "csaiot",
      "metadata": {
        "description": "Base name for all resources (will be suffixed)"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for deployment"
      }
    },
    "iotHubSku": {
      "type": "string",
      "defaultValue": "S1",
      "allowedValues": [
        "F1",
        "S1",
        "S2",
        "S3"
      ],
      "metadata": {
        "description": "IoT Hub SKU"
      }
    },
    "iotHubCapacity": {
      "type": "int",
      "defaultValue": 1,
      "metadata": {
        "description": "IoT Hub SKU capacity (number of units)"
      }
    },
    "eventHubSku": {
      "type": "string",
      "defaultValue": "Standard",
      "allowedValues": [
        "Basic",
        "Standard",
        "Premium"
      ],
      "metadata": {
        "description": "Event Hub namespace SKU"
      }
    },
    "partitionCount": {
      "type": "int",
      "defaultValue": 4,
      "metadata": {
        "description": "Event Hub partition count"
      }
    },
    "messageRetentionDays": {
      "type": "int",
      "defaultValue": 7,
      "metadata": {
        "description": "Event Hub message retention in days"
      }
    },
    "captureStorageAccountName": {
      "type": "string",
      "metadata": {
        "description": "ADLS Gen2 storage account name for Event Hub Capture"
      }
    },
    "captureContainerName": {
      "type": "string",
      "defaultValue": "bronze",
      "metadata": {
        "description": "ADLS Gen2 container name for capture output"
      }
    },
    "logAnalyticsWorkspaceId": {
      "type": "string",
      "metadata": {
        "description": "Log Analytics workspace resource ID for diagnostics"
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {
        "Project": "CSA-in-a-Box",
        "Component": "IoT-Streaming",
        "Environment": "dev"
      },
      "metadata": {
        "description": "Tags to apply to all resources"
      }
    }
  },
  "variables": {
    "iotHubName": "[format('{0}-iothub', parameters('baseName'))]",
    "dpsName": "[format('{0}-dps', parameters('baseName'))]",
    "eventHubNamespaceName": "[format('{0}-ehns', parameters('baseName'))]",
    "telemetryHubName": "telemetry",
    "alertsHubName": "alerts",
    "processedHubName": "processed",
    "adxConsumerGroup": "adx-consumer",
    "asaConsumerGroup": "asa-consumer",
    "captureConsumerGroup": "capture-consumer",
    "sendRuleName": "SendRule",
    "listenRuleName": "ListenRule",
    "manageRuleName": "ManageRule"
  },
  "resources": [
    {
      "type": "Microsoft.EventHub/namespaces",
      "apiVersion": "2024-01-01",
      "name": "[variables('eventHubNamespaceName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "[parameters('eventHubSku')]",
        "tier": "[parameters('eventHubSku')]",
        "capacity": 1
      },
      "properties": {
        "isAutoInflateEnabled": "[equals(parameters('eventHubSku'), 'Standard')]",
        "maximumThroughputUnits": "[if(equals(parameters('eventHubSku'), 'Standard'), 10, 0)]",
        "kafkaEnabled": "[not(equals(parameters('eventHubSku'), 'Basic'))]",
        "minimumTlsVersion": "1.2",
        "publicNetworkAccess": "Enabled",
        "disableLocalAuth": false,
        "zoneRedundant": true
      }
    },
    {
      "type": "Microsoft.EventHub/namespaces/eventhubs",
      "apiVersion": "2024-01-01",
      "name": "[format('{0}/{1}', variables('eventHubNamespaceName'), variables('telemetryHubName'))]",
      "properties": {
        "partitionCount": "[parameters('partitionCount')]",
        "messageRetentionInDays": "[parameters('messageRetentionDays')]",
        "captureDescription": {
          "enabled": true,
          "encoding": "Avro",
          "intervalInSeconds": 300,
          "sizeLimitInBytes": 314572800,
          "destination": {
            "name": "EventHubArchive.AzureBlockBlob",
            "properties": {
              "storageAccountResourceId": "[resourceId('Microsoft.Storage/storageAccounts', parameters('captureStorageAccountName'))]",
              "blobContainer": "[parameters('captureContainerName')]",
              "archiveNameFormat": "{Namespace}/{EventHub}/{PartitionId}/{Year}/{Month}/{Day}/{Hour}/{Minute}/{Second}"
            }
          },
          "skipEmptyArchives": true
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.EventHub/namespaces', variables('eventHubNamespaceName'))]"
      ]
    },
    {
      "type": "Microsoft.EventHub/namespaces/eventhubs",
      "apiVersion": "2024-01-01",
      "name": "[format('{0}/{1}', variables('eventHubNamespaceName'), variables('alertsHubName'))]",
      "properties": {
        "partitionCount": 2,
        "messageRetentionInDays": 3
      },
      "dependsOn": [
        "[resourceId('Microsoft.EventHub/namespaces', variables('eventHubNamespaceName'))]"
      ]
    },
    {
      "type": "Microsoft.EventHub/namespaces/eventhubs",
      "apiVersion": "2024-01-01",
      "name": "[format('{0}/{1}', variables('eventHubNamespaceName'), variables('processedHubName'))]",
      "properties": {
        "partitionCount": "[parameters('partitionCount')]",
        "messageRetentionInDays": "[parameters('messageRetentionDays')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.EventHub/namespaces', variables('eventHubNamespaceName'))]"
      ]
    },
    {
      "type": "Microsoft.EventHub/namespaces/eventhubs/consumergroups",
      "apiVersion": "2024-01-01",
      "name": "[format('{0}/{1}/{2}', variables('eventHubNamespaceName'), variables('telemetryHubName'), variables('adxConsumerGroup'))]",
      "properties": {
        "userMetadata": "Consumer group for Azure Data Explorer real-time ingestion"
      },
      "dependsOn": [
        "[resourceId('Microsoft.EventHub/namespaces/eventhubs', variables('eventHubNamespaceName'), variables('telemetryHubName'))]"
      ]
    },
    {
      "type": "Microsoft.EventHub/namespaces/eventhubs/consumergroups",
      "apiVersion": "2024-01-01",
      "name": "[format('{0}/{1}/{2}', variables('eventHubNamespaceName'), variables('telemetryHubName'), variables('asaConsumerGroup'))]",
      "properties": {
        "userMetadata": "Consumer group for Stream Analytics windowed aggregation"
      },
      "dependsOn": [
        "[resourceId('Microsoft.EventHub/namespaces/eventhubs', variables('eventHubNamespaceName'), variables('telemetryHubName'))]"
      ]
    },
    {
      "type": "Microsoft.EventHub/namespaces/eventhubs/consumergroups",
      "apiVersion": "2024-01-01",
      "name": "[format('{0}/{1}/{2}', variables('eventHubNamespaceName'), variables('telemetryHubName'), variables('captureConsumerGroup'))]",
      "properties": {
        "userMetadata": "Consumer group for ADLS Gen2 Capture cold path"
      },
      "dependsOn": [
        "[resourceId('Microsoft.EventHub/namespaces/eventhubs', variables('eventHubNamespaceName'), variables('telemetryHubName'))]"
      ]
    },
    {
      "type": "Microsoft.EventHub/namespaces/eventhubs/authorizationRules",
      "apiVersion": "2024-01-01",
      "name": "[format('{0}/{1}/{2}', variables('eventHubNamespaceName'), variables('telemetryHubName'), variables('sendRuleName'))]",
      "properties": {
        "rights": [
          "Send"
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.EventHub/namespaces/eventhubs', variables('eventHubNamespaceName'), variables('telemetryHubName'))]"
      ]
    },
    {
      "type": "Microsoft.EventHub/namespaces/eventhubs/authorizationRules",
      "apiVersion": "2024-01-01",
      "name": "[format('{0}/{1}/{2}', variables('eventHubNamespaceName'), variables('telemetryHubName'), variables('listenRuleName'))]",
      "properties": {
        "rights": [
          "Listen"
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.EventHub/namespaces/eventhubs', variables('eventHubNamespaceName'), variables('telemetryHubName'))]"
      ]
    },
    {
      "type": "Microsoft.EventHub/namespaces/authorizationRules",
      "apiVersion": "2024-01-01",
      "name": "[format('{0}/{1}', variables('eventHubNamespaceName'), variables('manageRuleName'))]",
      "properties": {
        "rights": [
          "Manage",
          "Send",
          "Listen"
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.EventHub/namespaces', variables('eventHubNamespaceName'))]"
      ]
    },
    {
      "type": "Microsoft.Devices/IotHubs",
      "apiVersion": "2023-06-30",
      "name": "[variables('iotHubName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "[parameters('iotHubSku')]",
        "capacity": "[parameters('iotHubCapacity')]"
      },
      "properties": {
        "eventHubEndpoints": {
          "events": {
            "retentionTimeInDays": 1,
            "partitionCount": "[parameters('partitionCount')]"
          }
        },
        "routing": {
          "endpoints": {
            "eventHubs": [
              {
                "name": "telemetry-route",
                "connectionString": "[listKeys(resourceId('Microsoft.EventHub/namespaces/eventhubs/authorizationRules', variables('eventHubNamespaceName'), variables('telemetryHubName'), variables('sendRuleName')), '2024-01-01').primaryConnectionString]",
                "resourceGroup": "[resourceGroup().name]",
                "subscriptionId": "[subscription().subscriptionId]"
              }
            ]
          },
          "routes": [
            {
              "name": "telemetry-to-eventhub",
              "source": "DeviceMessages",
              "condition": "true",
              "endpointNames": [
                "telemetry-route"
              ],
              "isEnabled": true
            },
            {
              "name": "twin-changes-to-builtin",
              "source": "TwinChangeEvents",
              "condition": "true",
              "endpointNames": [
                "events"
              ],
              "isEnabled": true
            }
          ],
          "fallbackRoute": {
            "name": "$fallback",
            "source": "DeviceMessages",
            "condition": "true",
            "endpointNames": [
              "events"
            ],
            "isEnabled": true
          }
        },
        "cloudToDevice": {
          "maxDeliveryCount": 10,
          "defaultTtlAsIso8601": "PT1H",
          "feedback": {
            "lockDurationAsIso8601": "PT60S",
            "ttlAsIso8601": "PT1H",
            "maxDeliveryCount": 10
          }
        },
        "features": "None",
        "minTlsVersion": "1.2",
        "disableLocalAuth": false
      },
      "dependsOn": [
        "[resourceId('Microsoft.EventHub/namespaces/eventhubs/authorizationRules', variables('eventHubNamespaceName'), variables('telemetryHubName'), variables('sendRuleName'))]"
      ]
    },
    {
      "type": "Microsoft.Devices/provisioningServices",
      "apiVersion": "2022-12-12",
      "name": "[variables('dpsName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "S1",
        "capacity": 1
      },
      "properties": {
        "iotHubs": [
          {
            "connectionString": "[format('HostName={0};SharedAccessKeyName=iothubowner;SharedAccessKey={1}', reference(resourceId('Microsoft.Devices/IotHubs', variables('iotHubName')), '2023-06-30').hostName, listKeys(resourceId('Microsoft.Devices/IotHubs', variables('iotHubName')), '2023-06-30').value[0].primaryKey)]",
            "location": "[parameters('location')]"
          }
        ],
        "allocationPolicy": "Hashed"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Devices/IotHubs', variables('iotHubName'))]"
      ]
    },
    {
      "type": "Microsoft.Insights/diagnosticSettings",
      "apiVersion": "2021-05-01-preview",
      "scope": "[resourceId('Microsoft.Devices/IotHubs', variables('iotHubName'))]",
      "name": "[format('{0}-diag', variables('iotHubName'))]",
      "properties": {
        "workspaceId": "[parameters('logAnalyticsWorkspaceId')]",
        "logs": [
          {
            "categoryGroup": "allLogs",
            "enabled": true
          }
        ],
        "metrics": [
          {
            "category": "AllMetrics",
            "enabled": true
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Devices/IotHubs', variables('iotHubName'))]"
      ]
    },
    {
      "type": "Microsoft.Insights/diagnosticSettings",
      "apiVersion": "2021-05-01-preview",
      "scope": "[resourceId('Microsoft.EventHub/namespaces', variables('eventHubNamespaceName'))]",
      "name": "[format('{0}-diag', variables('eventHubNamespaceName'))]",
      "properties": {
        "workspaceId": "[parameters('logAnalyticsWorkspaceId')]",
        "logs": [
          {
            "categoryGroup": "allLogs",
            "enabled": true
          }
        ],
        "metrics": [
          {
            "category": "AllMetrics",
            "enabled": true
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.EventHub/namespaces', variables('eventHubNamespaceName'))]"
      ]
    }
  ],
  "outputs": {
    "iotHubName": {
      "type": "string",
      "value": "[variables('iotHubName')]"
    },
    "iotHubHostName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Devices/IotHubs', variables('iotHubName')), '2023-06-30').hostName]"
    },
    "dpsName": {
      "type": "string",
      "value": "[variables('dpsName')]"
    },
    "dpsIdScope": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Devices/provisioningServices', variables('dpsName')), '2022-12-12').idScope]"
    },
    "eventHubNamespaceName": {
      "type": "string",
      "value": "[variables('eventHubNamespaceName')]"
    },
    "telemetryHubName": {
      "type": "string",
      "value": "[variables('telemetryHubName')]"
    },
    "alertsHubName": {
      "type": "string",
      "value": "[variables('alertsHubName')]"
    },
    "processedHubName": {
      "type": "string",
      "value": "[variables('processedHubName')]"
    },
    "eventHubNamespaceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.EventHub/namespaces', variables('eventHubNamespaceName'))]"
    },
    "telemetryHubSendConnectionString": {
      "type": "string",
      "value": "[listKeys(resourceId('Microsoft.EventHub/namespaces/eventhubs/authorizationRules', variables('eventHubNamespaceName'), variables('telemetryHubName'), variables('sendRuleName')), '2024-01-01').primaryConnectionString]"
    },
    "telemetryHubListenConnectionString": {
      "type": "string",
      "value": "[listKeys(resourceId('Microsoft.EventHub/namespaces/eventhubs/authorizationRules', variables('eventHubNamespaceName'), variables('telemetryHubName'), variables('listenRuleName')), '2024-01-01').primaryConnectionString]"
    }
  }
}