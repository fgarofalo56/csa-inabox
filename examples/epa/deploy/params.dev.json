{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "location": {
            "value": "East US 2"
        },
        "environment": {
            "value": "dev"
        },
        "prefix": {
            "value": "epa"
        },
        "workloadName": {
            "value": "environmental-monitoring-analytics"
        },
        "deployModules": {
            "value": {
                "cosmosDB": true,
                "storageZones": true,
                "externalStorage": false,
                "synapse": true,
                "functions": true,
                "streamAnalytics": false,
                "appInsights": true,
                "privateEndpoints": true,
                "genericStorage": false,
                "selfHostedIR": false,
                "dataExplorer": true,
                "mlWorkspace": true
            }
        },
        "privateDNSZones": {
            "value": {
                "subscriptionId": "[subscription().subscriptionId]",
                "resourceGroupName": "rg-dns-zones"
            }
        },
        "tags": {
            "value": {
                "Domain": "EPA",
                "Environment": "Development",
                "WorkloadType": "Analytics",
                "CostCenter": "EPA-IT",
                "Owner": "EPA Data Engineering Team",
                "Project": "Environmental Monitoring Analytics Platform"
            }
        },
        "databricksConfig": {
            "value": {
                "pricingTier": "premium",
                "enableNoPublicIp": true,
                "skuName": "premium",
                "customVirtualNetworkId": "",
                "customPublicSubnetName": "",
                "customPrivateSubnetName": "",
                "enableAutomaticClusterTermination": true
            }
        },
        "synapseConfig": {
            "value": {
                "sqlAdministratorLogin": "sqladmin",
                "sqlAdministratorLoginPassword": "[parameters('sqlAdministratorPassword')]",
                "allowedIpAddresses": [
                    {
                        "name": "EPA-HQ",
                        "startIpAddress": "192.168.5.0",
                        "endIpAddress": "192.168.5.255"
                    }
                ],
                "enableDataExfiltrationProtection": true,
                "managedVirtualNetwork": "default",
                "gitConfig": {
                    "accountName": "EPA-Analytics",
                    "repositoryName": "epa-environmental-monitoring-analytics",
                    "collaborationBranch": "main",
                    "rootFolder": "/synapse"
                }
            }
        },
        "storageConfig": {
            "value": {
                "accountType": "Standard_LRS",
                "accessTier": "Hot",
                "supportsHttpsTrafficOnly": true,
                "enableHierarchicalNamespace": true,
                "containers": [
                    {
                        "name": "raw",
                        "publicAccess": "None"
                    },
                    {
                        "name": "bronze",
                        "publicAccess": "None"
                    },
                    {
                        "name": "silver",
                        "publicAccess": "None"
                    },
                    {
                        "name": "gold",
                        "publicAccess": "None"
                    },
                    {
                        "name": "exports",
                        "publicAccess": "None"
                    },
                    {
                        "name": "aqs-air-quality",
                        "publicAccess": "None"
                    },
                    {
                        "name": "sdwis-water",
                        "publicAccess": "None"
                    },
                    {
                        "name": "tri-releases",
                        "publicAccess": "None"
                    },
                    {
                        "name": "echo-compliance",
                        "publicAccess": "None"
                    }
                ]
            }
        },
        "keyVaultConfig": {
            "value": {
                "enableRbacAuthorization": true,
                "enableSoftDelete": true,
                "softDeleteRetentionDays": 90,
                "enablePurgeProtection": true,
                "secrets": [
                    {
                        "name": "airnow-api-key",
                        "description": "EPA AirNow API key for air quality data"
                    },
                    {
                        "name": "echo-api-token",
                        "description": "EPA ECHO API token for compliance data"
                    },
                    {
                        "name": "sql-administrator-password",
                        "description": "SQL administrator password for Synapse"
                    }
                ]
            }
        },
        "dataFactoryConfig": {
            "value": {
                "publicNetworkAccess": "Enabled",
                "gitConfig": {
                    "accountName": "EPA-Analytics",
                    "repositoryName": "epa-environmental-monitoring-analytics",
                    "collaborationBranch": "main",
                    "rootFolder": "/datafactory"
                },
                "integrationRuntimes": [
                    {
                        "name": "AutoResolveIntegrationRuntime",
                        "type": "Managed",
                        "location": "AutoResolve"
                    }
                ],
                "linkedServices": [
                    {
                        "name": "ls_keyvault",
                        "type": "AzureKeyVault"
                    },
                    {
                        "name": "ls_storage_raw",
                        "type": "AzureDataLakeStorage"
                    },
                    {
                        "name": "ls_synapse",
                        "type": "AzureSqlDW"
                    },
                    {
                        "name": "ls_airnow_api",
                        "type": "RestService",
                        "baseUrl": "https://www.airnowapi.org/aq/"
                    },
                    {
                        "name": "ls_echo_api",
                        "type": "RestService",
                        "baseUrl": "https://echodata.epa.gov/echo/"
                    }
                ]
            }
        },
        "dataExplorerConfig": {
            "value": {
                "skuName": "Dev(No SLA)_Standard_D11_v2",
                "skuTier": "Basic",
                "capacity": 1,
                "enableDiskEncryption": false,
                "enableStreamingIngest": true,
                "enablePurge": true,
                "databases": [
                    {
                        "name": "epaanalytics",
                        "hotCachePeriod": "P7D",
                        "softDeletePeriod": "P365D"
                    }
                ],
                "enableAutoStop": true,
                "enableAutoScale": false
            }
        },
        "mlWorkspaceConfig": {
            "value": {
                "friendlyName": "EPA Environmental Monitoring ML",
                "description": "Machine learning workspace for air quality forecasting and environmental justice analytics",
                "enablePublicNetworkAccess": "Enabled",
                "computeInstances": [
                    {
                        "name": "aqi-forecasting-vm",
                        "vmSize": "Standard_DS3_v2",
                        "enableNodePublicIp": false
                    }
                ],
                "datastores": [
                    {
                        "name": "environmental_data",
                        "type": "AzureDataLakeGen2",
                        "description": "Primary environmental monitoring datasets"
                    }
                ]
            }
        },
        "monitoringConfig": {
            "value": {
                "enableApplicationInsights": true,
                "enableLogAnalytics": true,
                "retentionInDays": 90,
                "alertRules": [
                    {
                        "name": "Air Quality Data Pipeline Failure",
                        "severity": 2,
                        "evaluationFrequency": "PT5M",
                        "windowSize": "PT15M",
                        "actionGroupName": "epa-alerts"
                    },
                    {
                        "name": "AQI Exceedance Alert",
                        "severity": 1,
                        "evaluationFrequency": "PT1H",
                        "windowSize": "PT1H",
                        "actionGroupName": "epa-alerts"
                    }
                ],
                "actionGroups": [
                    {
                        "name": "epa-alerts",
                        "emailReceivers": [
                            {
                                "name": "EPA Data Team",
                                "emailAddress": "epa-data-team@contoso.com"
                            }
                        ]
                    }
                ]
            }
        },
        "networkingConfig": {
            "value": {
                "enablePrivateEndpoints": true,
                "subnetName": "snet-epa-analytics",
                "vnetName": "vnet-epa-analytics",
                "vnetAddressPrefix": "10.6.0.0/16",
                "subnetAddressPrefix": "10.6.1.0/24",
                "enableNetworkSecurityGroup": true,
                "allowedSourceIpRanges": [
                    "192.168.5.0/24",
                    "10.0.0.0/8"
                ]
            }
        },
        "securityConfig": {
            "value": {
                "enableDefender": true,
                "enableKeyVaultFirewall": true,
                "enableStorageFirewall": true,
                "requireHttpsTrafficOnly": true,
                "enableAuditLogs": true,
                "dataClassification": {
                    "enabled": true,
                    "level": "Sensitive"
                },
                "encryptionAtRest": true,
                "enablePrivateLink": true
            }
        },
        "automationConfig": {
            "value": {
                "enableAutoShutdown": true,
                "autoShutdownTime": "19:00",
                "autoShutdownTimeZone": "Eastern Standard Time",
                "enableCostOptimization": true,
                "enableResourceTagging": true,
                "backupRetentionDays": 30
            }
        },
        "dataGovernanceConfig": {
            "value": {
                "enablePurview": false,
                "dataRetentionPolicies": [
                    {
                        "dataType": "Raw AQS Air Quality Data",
                        "retentionDays": 2555
                    },
                    {
                        "dataType": "Processed Environmental Analytics",
                        "retentionDays": 1825
                    },
                    {
                        "dataType": "Audit Logs",
                        "retentionDays": 2190
                    }
                ],
                "enableDataLineage": true,
                "enableDataQualityMonitoring": true
            }
        }
    }
}