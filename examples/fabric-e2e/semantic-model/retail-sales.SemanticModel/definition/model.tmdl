model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

	annotation TabularEditor_SerializeOptions = {"IgnoreInferredObjects":true,"IgnoreInferredProperties":true,"IgnoreTimestamps":true,"SplitMultilineStrings":true,"PrefixFilenames":false,"LocalTranslations":false,"LocalPerspectives":false,"LocalRelationships":true,"Levels":["Data Sources","Shared Expressions","Perspectives","Relationships","Roles","Tables","Tables/Columns","Tables/Hierarchies","Tables/Measures","Tables/Partitions"]}
	annotation PBI_QueryOrder = ["DimCustomer","DimProduct","DimDate","FactSales"]
	annotation __PBI_TimeIntelligenceEnabled = 1
	annotation PBIDesktopVersion = 2.135.7886.0
	annotation PBI_ProTooling = ["DevMode"]

	ref table DimCustomer
	ref table DimProduct
	ref table DimDate
	ref table FactSales

	ref cultureInfo en-US

queryGroup 'Lakehouse'
	annotation PBI_QueryGroupOrder = 0

expression 'OneLake Lakehouse' =
		let
			Source = Sql.Database("xxxx-xxxx-xxxx.datawarehouse.fabric.microsoft.com", "lh-retail-sales-gold")
		in
			Source
	meta [IsParameterQuery=null, IsParameterQueryRequired=null, Type="Any", Categories=#"#__not__set__"]

	queryGroup: 'Lakehouse'
