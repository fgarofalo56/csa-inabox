{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "location": {
            "value": "East US 2"
        },
        "environment": {
            "value": "dev"
        },
        "prefix": {
            "value": "interior"
        },
        "workloadName": {
            "value": "geospatial-analytics"
        },
        "deployModules": {
            "value": {
                "cosmosDB": true,
                "storageZones": true,
                "externalStorage": false,
                "synapse": true,
                "functions": true,
                "streamAnalytics": true,
                "appInsights": true,
                "privateEndpoints": true,
                "genericStorage": false,
                "selfHostedIR": false,
                "dataExplorer": true,
                "mlWorkspace": true
            }
        },
        "privateDNSZones": {
            "value": {
                "subscriptionId": "[subscription().subscriptionId]",
                "resourceGroupName": "rg-dns-zones"
            }
        },
        "tags": {
            "value": {
                "Domain": "Interior",
                "Environment": "Development",
                "WorkloadType": "Analytics",
                "CostCenter": "DOI-IT",
                "Owner": "Interior Data Engineering Team",
                "Project": "Geospatial Analytics Platform"
            }
        },
        "databricksConfig": {
            "value": {
                "pricingTier": "premium",
                "enableNoPublicIp": true,
                "skuName": "premium",
                "customVirtualNetworkId": "",
                "customPublicSubnetName": "",
                "customPrivateSubnetName": "",
                "enableAutomaticClusterTermination": true
            }
        },
        "synapseConfig": {
            "value": {
                "sqlAdministratorLogin": "sqladmin",
                "sqlAdministratorLoginPassword": "[parameters('sqlAdministratorPassword')]",
                "allowedIpAddresses": [
                    {
                        "name": "Interior-HQ",
                        "startIpAddress": "192.168.20.0",
                        "endIpAddress": "192.168.20.255"
                    }
                ],
                "enableDataExfiltrationProtection": true,
                "managedVirtualNetwork": "default",
                "gitConfig": {
                    "accountName": "Interior-Analytics",
                    "repositoryName": "interior-geospatial-analytics",
                    "collaborationBranch": "main",
                    "rootFolder": "/synapse"
                }
            }
        },
        "storageConfig": {
            "value": {
                "accountType": "Standard_LRS",
                "accessTier": "Hot",
                "supportsHttpsTrafficOnly": true,
                "enableHierarchicalNamespace": true,
                "containers": [
                    {
                        "name": "raw",
                        "publicAccess": "None"
                    },
                    {
                        "name": "bronze",
                        "publicAccess": "None"
                    },
                    {
                        "name": "silver",
                        "publicAccess": "None"
                    },
                    {
                        "name": "gold",
                        "publicAccess": "None"
                    },
                    {
                        "name": "exports",
                        "publicAccess": "None"
                    },
                    {
                        "name": "usgs-earthquake-data",
                        "publicAccess": "None"
                    },
                    {
                        "name": "nps-visitor-data",
                        "publicAccess": "None"
                    },
                    {
                        "name": "usgs-water-data",
                        "publicAccess": "None"
                    }
                ]
            }
        },
        "keyVaultConfig": {
            "value": {
                "enableRbacAuthorization": true,
                "enableSoftDelete": true,
                "softDeleteRetentionDays": 90,
                "enablePurgeProtection": true,
                "secrets": [
                    {
                        "name": "nps-api-key",
                        "description": "NPS Developer API key"
                    },
                    {
                        "name": "sql-administrator-password",
                        "description": "SQL administrator password for Synapse"
                    }
                ]
            }
        },
        "dataFactoryConfig": {
            "value": {
                "publicNetworkAccess": "Enabled",
                "gitConfig": {
                    "accountName": "Interior-Analytics",
                    "repositoryName": "interior-geospatial-analytics",
                    "collaborationBranch": "main",
                    "rootFolder": "/datafactory"
                },
                "integrationRuntimes": [
                    {
                        "name": "AutoResolveIntegrationRuntime",
                        "type": "Managed",
                        "location": "AutoResolve"
                    }
                ],
                "linkedServices": [
                    {
                        "name": "ls_keyvault",
                        "type": "AzureKeyVault"
                    },
                    {
                        "name": "ls_storage_raw",
                        "type": "AzureDataLakeStorage"
                    },
                    {
                        "name": "ls_synapse",
                        "type": "AzureSqlDW"
                    },
                    {
                        "name": "ls_usgs_earthquake_api",
                        "type": "RestService",
                        "baseUrl": "https://earthquake.usgs.gov/fdsnws/event/1/"
                    },
                    {
                        "name": "ls_usgs_water_api",
                        "type": "RestService",
                        "baseUrl": "https://waterservices.usgs.gov/nwis/"
                    },
                    {
                        "name": "ls_nps_stats_api",
                        "type": "RestService",
                        "baseUrl": "https://irmaservices.nps.gov/stats/"
                    }
                ]
            }
        },
        "dataExplorerConfig": {
            "value": {
                "skuName": "Dev(No SLA)_Standard_D11_v2",
                "skuTier": "Basic",
                "capacity": 1,
                "enableDiskEncryption": false,
                "enableStreamingIngest": true,
                "enablePurge": true,
                "databases": [
                    {
                        "name": "interioranalytics",
                        "hotCachePeriod": "P7D",
                        "softDeletePeriod": "P365D"
                    }
                ],
                "enableAutoStop": true,
                "enableAutoScale": false
            }
        },
        "mlWorkspaceConfig": {
            "value": {
                "friendlyName": "Interior Geospatial Analytics ML",
                "description": "Machine learning workspace for hazard prediction and resource management",
                "enablePublicNetworkAccess": "Enabled",
                "computeInstances": [
                    {
                        "name": "hazard-forecasting-vm",
                        "vmSize": "Standard_DS3_v2",
                        "enableNodePublicIp": false
                    }
                ],
                "datastores": [
                    {
                        "name": "geospatial_data",
                        "type": "AzureDataLakeGen2",
                        "description": "Primary geospatial datasets"
                    }
                ]
            }
        },
        "monitoringConfig": {
            "value": {
                "enableApplicationInsights": true,
                "enableLogAnalytics": true,
                "retentionInDays": 90,
                "alertRules": [
                    {
                        "name": "Data Pipeline Failure",
                        "severity": 2,
                        "evaluationFrequency": "PT5M",
                        "windowSize": "PT15M",
                        "actionGroupName": "interior-alerts"
                    },
                    {
                        "name": "Significant Earthquake Detected",
                        "severity": 0,
                        "evaluationFrequency": "PT1M",
                        "windowSize": "PT5M",
                        "actionGroupName": "interior-alerts"
                    }
                ],
                "actionGroups": [
                    {
                        "name": "interior-alerts",
                        "emailReceivers": [
                            {
                                "name": "Interior Data Team",
                                "emailAddress": "interior-data-team@contoso.com"
                            }
                        ]
                    }
                ]
            }
        },
        "networkingConfig": {
            "value": {
                "enablePrivateEndpoints": true,
                "subnetName": "snet-interior-analytics",
                "vnetName": "vnet-interior-analytics",
                "vnetAddressPrefix": "10.4.0.0/16",
                "subnetAddressPrefix": "10.4.1.0/24",
                "enableNetworkSecurityGroup": true,
                "allowedSourceIpRanges": [
                    "192.168.20.0/24",
                    "10.0.0.0/8"
                ]
            }
        },
        "securityConfig": {
            "value": {
                "enableDefender": true,
                "enableKeyVaultFirewall": true,
                "enableStorageFirewall": true,
                "requireHttpsTrafficOnly": true,
                "enableAuditLogs": true,
                "dataClassification": {
                    "enabled": true,
                    "level": "Sensitive"
                },
                "encryptionAtRest": true,
                "enablePrivateLink": true
            }
        },
        "automationConfig": {
            "value": {
                "enableAutoShutdown": true,
                "autoShutdownTime": "19:00",
                "autoShutdownTimeZone": "Eastern Standard Time",
                "enableCostOptimization": true,
                "enableResourceTagging": true,
                "backupRetentionDays": 30
            }
        },
        "dataGovernanceConfig": {
            "value": {
                "enablePurview": false,
                "dataRetentionPolicies": [
                    {
                        "dataType": "USGS Earthquake Data",
                        "retentionDays": 2555
                    },
                    {
                        "dataType": "NPS Visitor Data",
                        "retentionDays": 2555
                    },
                    {
                        "dataType": "USGS Water Data",
                        "retentionDays": 2555
                    },
                    {
                        "dataType": "Processed Analytics",
                        "retentionDays": 1825
                    },
                    {
                        "dataType": "Audit Logs",
                        "retentionDays": 2190
                    }
                ],
                "enableDataLineage": true,
                "enableDataQualityMonitoring": true
            }
        }
    }
}