{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "location": {
            "value": "USGov Virginia"
        },
        "environment": {
            "value": "gov"
        },
        "prefix": {
            "value": "dot"
        },
        "workloadName": {
            "value": "transportation-safety-analytics"
        },
        "deployModules": {
            "value": {
                "cosmosDB": true,
                "storageZones": true,
                "externalStorage": false,
                "synapse": true,
                "functions": true,
                "streamAnalytics": false,
                "appInsights": true,
                "privateEndpoints": true,
                "genericStorage": false,
                "selfHostedIR": false,
                "dataExplorer": true,
                "mlWorkspace": true
            }
        },
        "privateDNSZones": {
            "value": {
                "subscriptionId": "[subscription().subscriptionId]",
                "resourceGroupName": "rg-dns-zones-gov"
            }
        },
        "tags": {
            "value": {
                "Domain": "DOT",
                "Environment": "Government",
                "WorkloadType": "Analytics",
                "CostCenter": "DOT-IT-GOV",
                "Owner": "DOT Data Engineering Team",
                "Project": "Transportation Safety Analytics Platform",
                "Compliance": "FISMA-High",
                "DataClassification": "CUI",
                "AuthorityToOperate": "DOT-ATO-2024"
            }
        },
        "databricksConfig": {
            "value": {
                "pricingTier": "premium",
                "enableNoPublicIp": true,
                "skuName": "premium",
                "customVirtualNetworkId": "",
                "customPublicSubnetName": "",
                "customPrivateSubnetName": "",
                "enableAutomaticClusterTermination": true,
                "enableEncryption": true
            }
        },
        "synapseConfig": {
            "value": {
                "sqlAdministratorLogin": "sqladmin",
                "sqlAdministratorLoginPassword": "[parameters('sqlAdministratorPassword')]",
                "allowedIpAddresses": [
                    {
                        "name": "DOT-GOV-HQ",
                        "startIpAddress": "192.168.102.0",
                        "endIpAddress": "192.168.102.255"
                    },
                    {
                        "name": "DOT-GOV-FIELD",
                        "startIpAddress": "192.168.103.0",
                        "endIpAddress": "192.168.103.255"
                    }
                ],
                "enableDataExfiltrationProtection": true,
                "managedVirtualNetwork": "default",
                "enableDoubleEncryption": true,
                "gitConfig": {
                    "accountName": "DOT-Analytics-Gov",
                    "repositoryName": "dot-transportation-safety-analytics-gov",
                    "collaborationBranch": "main",
                    "rootFolder": "/synapse"
                }
            }
        },
        "storageConfig": {
            "value": {
                "accountType": "Standard_GRS",
                "accessTier": "Hot",
                "supportsHttpsTrafficOnly": true,
                "enableHierarchicalNamespace": true,
                "minimumTlsVersion": "TLS1_2",
                "allowBlobPublicAccess": false,
                "enableCrossTenantReplication": false,
                "containers": [
                    {
                        "name": "raw",
                        "publicAccess": "None"
                    },
                    {
                        "name": "bronze",
                        "publicAccess": "None"
                    },
                    {
                        "name": "silver",
                        "publicAccess": "None"
                    },
                    {
                        "name": "gold",
                        "publicAccess": "None"
                    },
                    {
                        "name": "exports",
                        "publicAccess": "None"
                    },
                    {
                        "name": "fars-crash-data",
                        "publicAccess": "None"
                    },
                    {
                        "name": "nbi-bridge-data",
                        "publicAccess": "None"
                    },
                    {
                        "name": "ntd-transit-data",
                        "publicAccess": "None"
                    },
                    {
                        "name": "audit-logs",
                        "publicAccess": "None"
                    }
                ],
                "enableVersioning": true,
                "enableDeleteRetention": true,
                "deleteRetentionDays": 365
            }
        },
        "keyVaultConfig": {
            "value": {
                "enableRbacAuthorization": true,
                "enableSoftDelete": true,
                "softDeleteRetentionDays": 90,
                "enablePurgeProtection": true,
                "enabledForDiskEncryption": true,
                "enabledForDeployment": false,
                "enabledForTemplateDeployment": false,
                "networkAccessPolicy": "deny",
                "secrets": [
                    {
                        "name": "fars-api-key",
                        "description": "NHTSA FARS CrashAPI access key"
                    },
                    {
                        "name": "soda-api-token",
                        "description": "Socrata Open Data API token for data.transportation.gov"
                    },
                    {
                        "name": "sql-administrator-password",
                        "description": "SQL administrator password for Synapse"
                    },
                    {
                        "name": "encryption-key",
                        "description": "Customer-managed encryption key"
                    }
                ]
            }
        },
        "dataFactoryConfig": {
            "value": {
                "publicNetworkAccess": "Disabled",
                "managedVirtualNetworkSettings": {
                    "allowedPrivateEndpointConnections": [],
                    "preventDataExfiltration": true
                },
                "gitConfig": {
                    "accountName": "DOT-Analytics-Gov",
                    "repositoryName": "dot-transportation-safety-analytics-gov",
                    "collaborationBranch": "main",
                    "rootFolder": "/datafactory"
                },
                "integrationRuntimes": [
                    {
                        "name": "AutoResolveIntegrationRuntime",
                        "type": "Managed",
                        "location": "USGov Virginia"
                    }
                ],
                "linkedServices": [
                    {
                        "name": "ls_keyvault",
                        "type": "AzureKeyVault"
                    },
                    {
                        "name": "ls_storage_raw",
                        "type": "AzureDataLakeStorage"
                    },
                    {
                        "name": "ls_synapse",
                        "type": "AzureSqlDW"
                    },
                    {
                        "name": "ls_fars_api",
                        "type": "RestService",
                        "baseUrl": "https://crashviewer.nhtsa.dot.gov/CrashAPI/"
                    },
                    {
                        "name": "ls_transportation_data",
                        "type": "RestService",
                        "baseUrl": "https://data.transportation.gov/resource/"
                    }
                ]
            }
        },
        "dataExplorerConfig": {
            "value": {
                "skuName": "Standard_D11_v2",
                "skuTier": "Standard",
                "capacity": 2,
                "enableDiskEncryption": true,
                "enableStreamingIngest": true,
                "enablePurge": true,
                "enableDoubleEncryption": true,
                "databases": [
                    {
                        "name": "dotanalytics",
                        "hotCachePeriod": "P30D",
                        "softDeletePeriod": "P2555D"
                    }
                ],
                "enableAutoStop": false,
                "enableAutoScale": true,
                "minimumInstances": 2,
                "maximumInstances": 10
            }
        },
        "mlWorkspaceConfig": {
            "value": {
                "friendlyName": "DOT Transportation Safety ML (Gov)",
                "description": "Machine learning workspace for highway safety prediction and crash severity analytics - Government Cloud",
                "enablePublicNetworkAccess": "Disabled",
                "enableHbiWorkspace": true,
                "computeInstances": [
                    {
                        "name": "crash-prediction-vm",
                        "vmSize": "Standard_DS3_v2",
                        "enableNodePublicIp": false
                    }
                ],
                "datastores": [
                    {
                        "name": "transportation_data",
                        "type": "AzureDataLakeGen2",
                        "description": "Primary transportation safety datasets"
                    }
                ]
            }
        },
        "monitoringConfig": {
            "value": {
                "enableApplicationInsights": true,
                "enableLogAnalytics": true,
                "retentionInDays": 2555,
                "enableSecurityCenter": true,
                "alertRules": [
                    {
                        "name": "Crash Data Pipeline Failure",
                        "severity": 1,
                        "evaluationFrequency": "PT5M",
                        "windowSize": "PT15M",
                        "actionGroupName": "dot-gov-alerts"
                    },
                    {
                        "name": "High Fatality Count Alert",
                        "severity": 0,
                        "evaluationFrequency": "PT30M",
                        "windowSize": "PT1H",
                        "actionGroupName": "dot-gov-alerts"
                    },
                    {
                        "name": "Unauthorized Access Attempt",
                        "severity": 0,
                        "evaluationFrequency": "PT1M",
                        "windowSize": "PT5M",
                        "actionGroupName": "dot-security-alerts"
                    },
                    {
                        "name": "Data Exfiltration Alert",
                        "severity": 0,
                        "evaluationFrequency": "PT5M",
                        "windowSize": "PT15M",
                        "actionGroupName": "dot-security-alerts"
                    }
                ],
                "actionGroups": [
                    {
                        "name": "dot-gov-alerts",
                        "emailReceivers": [
                            {
                                "name": "DOT Gov Data Team",
                                "emailAddress": "dot-safety-ops@dot.gov"
                            }
                        ]
                    },
                    {
                        "name": "dot-security-alerts",
                        "emailReceivers": [
                            {
                                "name": "DOT Security Operations",
                                "emailAddress": "dot-security-ops@dot.gov"
                            }
                        ]
                    }
                ]
            }
        },
        "networkingConfig": {
            "value": {
                "enablePrivateEndpoints": true,
                "subnetName": "snet-dot-analytics-gov",
                "vnetName": "vnet-dot-analytics-gov",
                "vnetAddressPrefix": "10.103.0.0/16",
                "subnetAddressPrefix": "10.103.1.0/24",
                "enableNetworkSecurityGroup": true,
                "allowedSourceIpRanges": [
                    "192.168.102.0/24",
                    "192.168.103.0/24"
                ],
                "enableDdosProtection": true,
                "enableBastionHost": true
            }
        },
        "securityConfig": {
            "value": {
                "enableDefender": true,
                "enableSentinel": true,
                "enableKeyVaultFirewall": true,
                "enableStorageFirewall": true,
                "requireHttpsTrafficOnly": true,
                "enableAuditLogs": true,
                "enableAdvancedThreatProtection": true,
                "dataClassification": {
                    "enabled": true,
                    "level": "CUI"
                },
                "encryptionAtRest": true,
                "enablePrivateLink": true,
                "enableCustomerManagedKeys": true,
                "complianceStandards": ["FISMA", "NIST-800-53", "FedRAMP"],
                "enableIdentityGovernance": true
            }
        },
        "automationConfig": {
            "value": {
                "enableAutoShutdown": false,
                "enableCostOptimization": true,
                "enableResourceTagging": true,
                "backupRetentionDays": 2555,
                "enableDisasterRecovery": true,
                "drRegion": "USGov Texas"
            }
        },
        "dataGovernanceConfig": {
            "value": {
                "enablePurview": true,
                "dataRetentionPolicies": [
                    {
                        "dataType": "Raw FARS Crash Data",
                        "retentionDays": 2555,
                        "complianceReason": "Federal Records Act"
                    },
                    {
                        "dataType": "Processed Safety Analytics",
                        "retentionDays": 2555,
                        "complianceReason": "Federal Records Act"
                    },
                    {
                        "dataType": "Audit Logs",
                        "retentionDays": 2555,
                        "complianceReason": "Security Compliance"
                    },
                    {
                        "dataType": "Personal Data",
                        "retentionDays": 1825,
                        "complianceReason": "Privacy Act"
                    }
                ],
                "enableDataLineage": true,
                "enableDataQualityMonitoring": true,
                "enableDataLossPrevention": true,
                "piiDetection": true,
                "enableDataEncryption": true
            }
        },
        "complianceConfig": {
            "value": {
                "fismaLevel": "High",
                "enableFedRAMP": true,
                "enableSOC2": false,
                "enableNIST": true,
                "auditRetentionYears": 7,
                "enableContinuousMonitoring": true,
                "securityContactEmail": "dot-security-ops@dot.gov",
                "privacyContactEmail": "dot-privacy-office@dot.gov"
            }
        }
    }
}