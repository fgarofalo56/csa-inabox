{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "location": {
            "value": "East US 2"
        },
        "environment": {
            "value": "dev"
        },
        "prefix": {
            "value": "dot"
        },
        "workloadName": {
            "value": "transportation-safety-analytics"
        },
        "deployModules": {
            "value": {
                "cosmosDB": true,
                "storageZones": true,
                "externalStorage": false,
                "synapse": true,
                "functions": true,
                "streamAnalytics": false,
                "appInsights": true,
                "privateEndpoints": true,
                "genericStorage": false,
                "selfHostedIR": false,
                "dataExplorer": true,
                "mlWorkspace": true
            }
        },
        "privateDNSZones": {
            "value": {
                "subscriptionId": "[subscription().subscriptionId]",
                "resourceGroupName": "rg-dns-zones"
            }
        },
        "tags": {
            "value": {
                "Domain": "DOT",
                "Environment": "Development",
                "WorkloadType": "Analytics",
                "CostCenter": "DOT-IT",
                "Owner": "DOT Data Engineering Team",
                "Project": "Transportation Safety Analytics Platform"
            }
        },
        "databricksConfig": {
            "value": {
                "pricingTier": "premium",
                "enableNoPublicIp": true,
                "skuName": "premium",
                "customVirtualNetworkId": "",
                "customPublicSubnetName": "",
                "customPrivateSubnetName": "",
                "enableAutomaticClusterTermination": true
            }
        },
        "synapseConfig": {
            "value": {
                "sqlAdministratorLogin": "sqladmin",
                "sqlAdministratorLoginPassword": "[parameters('sqlAdministratorPassword')]",
                "allowedIpAddresses": [
                    {
                        "name": "DOT-HQ",
                        "startIpAddress": "192.168.2.0",
                        "endIpAddress": "192.168.2.255"
                    }
                ],
                "enableDataExfiltrationProtection": true,
                "managedVirtualNetwork": "default",
                "gitConfig": {
                    "accountName": "DOT-Analytics",
                    "repositoryName": "dot-transportation-safety-analytics",
                    "collaborationBranch": "main",
                    "rootFolder": "/synapse"
                }
            }
        },
        "storageConfig": {
            "value": {
                "accountType": "Standard_LRS",
                "accessTier": "Hot",
                "supportsHttpsTrafficOnly": true,
                "enableHierarchicalNamespace": true,
                "containers": [
                    {
                        "name": "raw",
                        "publicAccess": "None"
                    },
                    {
                        "name": "bronze",
                        "publicAccess": "None"
                    },
                    {
                        "name": "silver",
                        "publicAccess": "None"
                    },
                    {
                        "name": "gold",
                        "publicAccess": "None"
                    },
                    {
                        "name": "exports",
                        "publicAccess": "None"
                    },
                    {
                        "name": "fars-crash-data",
                        "publicAccess": "None"
                    },
                    {
                        "name": "nbi-bridge-data",
                        "publicAccess": "None"
                    },
                    {
                        "name": "ntd-transit-data",
                        "publicAccess": "None"
                    }
                ]
            }
        },
        "keyVaultConfig": {
            "value": {
                "enableRbacAuthorization": true,
                "enableSoftDelete": true,
                "softDeleteRetentionDays": 90,
                "enablePurgeProtection": true,
                "secrets": [
                    {
                        "name": "fars-api-key",
                        "description": "NHTSA FARS CrashAPI access key"
                    },
                    {
                        "name": "soda-api-token",
                        "description": "Socrata Open Data API token for data.transportation.gov"
                    },
                    {
                        "name": "sql-administrator-password",
                        "description": "SQL administrator password for Synapse"
                    }
                ]
            }
        },
        "dataFactoryConfig": {
            "value": {
                "publicNetworkAccess": "Enabled",
                "gitConfig": {
                    "accountName": "DOT-Analytics",
                    "repositoryName": "dot-transportation-safety-analytics",
                    "collaborationBranch": "main",
                    "rootFolder": "/datafactory"
                },
                "integrationRuntimes": [
                    {
                        "name": "AutoResolveIntegrationRuntime",
                        "type": "Managed",
                        "location": "AutoResolve"
                    }
                ],
                "linkedServices": [
                    {
                        "name": "ls_keyvault",
                        "type": "AzureKeyVault"
                    },
                    {
                        "name": "ls_storage_raw",
                        "type": "AzureDataLakeStorage"
                    },
                    {
                        "name": "ls_synapse",
                        "type": "AzureSqlDW"
                    },
                    {
                        "name": "ls_fars_api",
                        "type": "RestService",
                        "baseUrl": "https://crashviewer.nhtsa.dot.gov/CrashAPI/"
                    },
                    {
                        "name": "ls_transportation_data",
                        "type": "RestService",
                        "baseUrl": "https://data.transportation.gov/resource/"
                    }
                ]
            }
        },
        "dataExplorerConfig": {
            "value": {
                "skuName": "Dev(No SLA)_Standard_D11_v2",
                "skuTier": "Basic",
                "capacity": 1,
                "enableDiskEncryption": false,
                "enableStreamingIngest": true,
                "enablePurge": true,
                "databases": [
                    {
                        "name": "dotanalytics",
                        "hotCachePeriod": "P7D",
                        "softDeletePeriod": "P365D"
                    }
                ],
                "enableAutoStop": true,
                "enableAutoScale": false
            }
        },
        "mlWorkspaceConfig": {
            "value": {
                "friendlyName": "DOT Transportation Safety ML",
                "description": "Machine learning workspace for highway safety prediction and crash severity analytics",
                "enablePublicNetworkAccess": "Enabled",
                "computeInstances": [
                    {
                        "name": "crash-prediction-vm",
                        "vmSize": "Standard_DS3_v2",
                        "enableNodePublicIp": false
                    }
                ],
                "datastores": [
                    {
                        "name": "transportation_data",
                        "type": "AzureDataLakeGen2",
                        "description": "Primary transportation safety datasets"
                    }
                ]
            }
        },
        "monitoringConfig": {
            "value": {
                "enableApplicationInsights": true,
                "enableLogAnalytics": true,
                "retentionInDays": 90,
                "alertRules": [
                    {
                        "name": "Crash Data Pipeline Failure",
                        "severity": 2,
                        "evaluationFrequency": "PT5M",
                        "windowSize": "PT15M",
                        "actionGroupName": "dot-alerts"
                    },
                    {
                        "name": "High Fatality Count Alert",
                        "severity": 1,
                        "evaluationFrequency": "PT1H",
                        "windowSize": "PT1H",
                        "actionGroupName": "dot-alerts"
                    }
                ],
                "actionGroups": [
                    {
                        "name": "dot-alerts",
                        "emailReceivers": [
                            {
                                "name": "DOT Data Team",
                                "emailAddress": "dot-data-team@contoso.com"
                            }
                        ]
                    }
                ]
            }
        },
        "networkingConfig": {
            "value": {
                "enablePrivateEndpoints": true,
                "subnetName": "snet-dot-analytics",
                "vnetName": "vnet-dot-analytics",
                "vnetAddressPrefix": "10.3.0.0/16",
                "subnetAddressPrefix": "10.3.1.0/24",
                "enableNetworkSecurityGroup": true,
                "allowedSourceIpRanges": [
                    "192.168.2.0/24",
                    "10.0.0.0/8"
                ]
            }
        },
        "securityConfig": {
            "value": {
                "enableDefender": true,
                "enableKeyVaultFirewall": true,
                "enableStorageFirewall": true,
                "requireHttpsTrafficOnly": true,
                "enableAuditLogs": true,
                "dataClassification": {
                    "enabled": true,
                    "level": "Sensitive"
                },
                "encryptionAtRest": true,
                "enablePrivateLink": true
            }
        },
        "automationConfig": {
            "value": {
                "enableAutoShutdown": true,
                "autoShutdownTime": "19:00",
                "autoShutdownTimeZone": "Eastern Standard Time",
                "enableCostOptimization": true,
                "enableResourceTagging": true,
                "backupRetentionDays": 30
            }
        },
        "dataGovernanceConfig": {
            "value": {
                "enablePurview": false,
                "dataRetentionPolicies": [
                    {
                        "dataType": "Raw FARS Crash Data",
                        "retentionDays": 2555
                    },
                    {
                        "dataType": "Processed Safety Analytics",
                        "retentionDays": 1825
                    },
                    {
                        "dataType": "Audit Logs",
                        "retentionDays": 2190
                    }
                ],
                "enableDataLineage": true,
                "enableDataQualityMonitoring": true
            }
        }
    }
}