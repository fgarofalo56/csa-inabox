# ==============================================================================
# CSA-in-a-Box .gitignore
# Cloud-Scale Analytics - Azure Data Platform
# ==============================================================================

# ---------------------------
# Secrets & Environment Files
# NEVER commit secrets, keys, tokens, or connection strings
# ---------------------------
.env
.env.*
*.env
local.settings.json
**/local.settings.json
appsettings.Development.json
**/appsettings.*.json
!**/appsettings.json

# ---------------------------
# Python Virtual Environments
# ---------------------------
.venv/
venv/
**/venv/
**/.venv/
**/dbt-env/
env/
ENV/

# ---------------------------
# Python Build / Cache
# ---------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
downloads/
eggs/
.eggs/
*.egg-info/
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt
*.whl

# ---------------------------
# Node.js
# ---------------------------
node_modules/
**/node_modules/
npm-debug.log*
yarn-error.log*

# ---------------------------
# IDE & Editor Settings
# Keep shared settings, ignore user-specific
# ---------------------------
.idea/
*.swp
*.swo
*~
.spyderproject/
.spyproject/
.ropeproject/

# VS Code - keep shared config, ignore user secrets
# Note: settings.json is tracked but MUST NOT contain passwords
.vscode/*.log
.vscode/.ropeproject/

# ---------------------------
# Azure Emulator & Local Runtime Files
# ---------------------------
__azurite_db_blob*
__azurite_db_queue*
__azurite_db_table*
__blobstorage__/
__queuestorage__/
__tablestorage__/
azurite-debug.log

# ---------------------------
# Azure Data Studio
# ---------------------------
.azuredatastudio/

# ---------------------------
# Testing & Coverage
# ---------------------------
.pytest_cache/
.tox/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.pytype/
*.cover
*.log
nosetests.xml
coverage.xml
*.coveragexml

# ---------------------------
# Jupyter Notebook Checkpoints
# ---------------------------
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# ---------------------------
# Large Binary Artifacts
# These should be in Azure Artifacts, Blob Storage, or Git LFS
# ---------------------------
domains/spark/ArcGIS_GeoAnalyticsEngine/
*.jar
!**/src/**/*.jar

# ---------------------------
# dbt
# ---------------------------
tools/dbt/dbt-env/
target/
dbt_packages/
dbt_modules/
logs/

# ---------------------------
# Terraform / IaC State (if used)
# ---------------------------
*.tfstate
*.tfstate.*
.terraform/
*.tfvars
!*.tfvars.example

# ---------------------------
# OS Files
# ---------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ---------------------------
# Build Outputs
# ---------------------------
*.manifest
*.spec
docs/_build/

# ---------------------------
# Generated / Temporary
# ---------------------------
temp/
tmp/
*.tmp
runs/
cache/
retrieval/
containers/
stats/

# ---------------------------
# CodeQL Database (large, generated)
# ---------------------------
codeqlDB/

# ---------------------------
# Framework-specific
# ---------------------------
local_settings.py
db.sqlite3
db.sqlite3-journal
instance/
.webassets-cache
.scrapy

# ---------------------------
# Project Management
# ---------------------------
.pdm.toml
.pybuilder/

# ---------------------------
# AI / ML
# ---------------------------
.genaiscript
*.onnx
*.pkl
*.h5
*.pt
!**/models/README.md
