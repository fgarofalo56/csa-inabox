# ---------------------------
# Byte-compiled / optimized files
# Python generates these files during execution to improve performance.
# They should not be included in version control.
# ---------------------------
__pycache__/
*.py[cod]
*$py.class

# ---------------------------
# C Extensions
# Compiled shared object files (.so) are platform-dependent and should not be committed.
# ---------------------------
*.so

# ---------------------------
# Distribution / Packaging
# These directories contain artifacts generated when building or distributing a Python package.
# They are not needed in the repository.
# ---------------------------
.Python
build/
dist/
downloads/
eggs/
.lib/
*.egg-info/
MANIFEST

# ---------------------------
# Local Configuration & Environment Files
# These files hold machine-specific settings, configurations, or secrets and should not be tracked.
# ---------------------------
.github/             # GitHub workflow and repository configurations (modify if needed).
.genaiscript        # Possible AI-generated script files (exclude unless essential).
.azuredatastudio/   # IDE-specific settings for Azure Data Studio.
.env                # Environment variables file, often contains sensitive information like API keys.
.venv/              # Python virtual environment. Dependencies should be managed using requirements.txt.
.vscode/            # VS Code settings folder (generally ignored, but keep shared settings).
!.vscode/settings.json
!.vscode/launch.json

# ---------------------------
# Cache & Temporary Files
# These files are generated during runtime and should not be stored in Git.
# ---------------------------
runs/
cache/
retrieval/
containers/
temp/
tests/              # Ignore test result data; keep test scripts separately.
stats/
*.csv               # Ignoring general CSV files, modify if needed.
.mypy_cache
.mypy_cache/       # MyPy cache for static type checking.

# ---------------------------
# PyInstaller Output
# These are generated when packaging a Python project into an executable.
# ---------------------------
*.manifest
*.spec

# ---------------------------
# Logs & Installer Reports
# These files contain logs from pip and other installations. Ignore them to keep the repo clean.
# ---------------------------
pip-log.txt
pip-delete-this-directory.txt
*.log

# ---------------------------
# Test Coverage & Reports
# Files generated when running tests, capturing coverage or debugging.
# ---------------------------
htmlcov/
.tox/
.coverage*
.pytest_cache/

# ---------------------------
# Framework-specific Files (Django, Flask, Scrapy, etc.)
# These are generated by various frameworks during development.
# ---------------------------
local_settings.py   # Django local settings (should not be tracked).
db.sqlite3         # SQLite database files (generated dynamically).
db.sqlite3-journal
instance/          # Flask instance folder (local configurations).
.webassets-cache   # Flask web assets.
.scrapy           # Scrapy cache folder.
docs/_build/      # Sphinx documentation build output.

# ---------------------------
# Project Management & Environment Files
# These contain configuration settings for various Python project management tools.
# ---------------------------
.pdm.toml          # PDM project-wide configurations (should not be committed).
.pybuilder/        # PyBuilder build folder.
.ipynb_checkpoints # Jupyter Notebook autosave checkpoints.
.pytype/           # Static type analysis cache.

# ---------------------------
# PyCharm / IDE Settings
# These contain workspace-specific configurations for JetBrains tools.
# ---------------------------
.idea/             # PyCharm workspace settings.
.spyderproject/
.spyproject/
.ropeproject/

# ---------------------------
# Paths to Ignore
# Ignoring specific folders related to project execution or external tools.
# ---------------------------
domains/spark/ArcGIS_GeoAnalyticsEngine/
.azuredatastudio/
__blob*/
tools/dbt/

# ---------------------------
# Specific File Exclusions
# Files that should be ignored as they do not need version control.
# ---------------------------
__azurite_db_blob*
Alerts.bicep
AzureBuiltIn*.csv
.fake