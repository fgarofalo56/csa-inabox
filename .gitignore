# ==============================================================================
# CSA-in-a-Box .gitignore
# Cloud-Scale Analytics - Azure Data Platform
# ==============================================================================

# ---------------------------
# Archived code — preserved for reference, excluded from CI/builds
# ---------------------------
_archived/**/node_modules/
_archived/**/__pycache__/
_archived/**/build/
_archived/**/.svelte-kit/

# ---------------------------
# Infracost (cost estimation cache)
# ---------------------------
.infracost/

# ---------------------------
# Portal persistence data (JSON store)
# ---------------------------
data/
# Un-ignore example verticals' data/ dirs (they host source generators).
# gitignore can only re-include files if the parent dir is un-ignored first.
!examples/*/data/
# Re-ignore generator *output* (fixtures produced at runtime).
examples/*/data/seed/

# ---------------------------
# Compiled Bicep output (regenerated by az bicep build)
# ---------------------------
deploy/bicep/**/*.json
!deploy/bicep/**/params*.json
!deploy/bicep/**/main.bicep

# IoT streaming & monitoring compiled Bicep ARM templates
examples/iot-streaming/deploy/bicep/*.json
monitoring/alerts/*.json
!monitoring/alerts/*.bicep

# ---------------------------
# Secrets & Environment Files
# NEVER commit secrets, keys, tokens, or connection strings
# ---------------------------
.env
.env.*
!.env.example
!**/.env.example
*.env
local.settings.json
**/local.settings.json
appsettings.Development.json
**/appsettings.*.json
!**/appsettings.json

# ---------------------------
# Python Virtual Environments
# ---------------------------
.venv/
venv/
**/venv/
**/.venv/
**/dbt-env/
env/
ENV/

# ---------------------------
# Python Build / Cache
# ---------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
downloads/
eggs/
.eggs/
*.egg-info/
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt
*.whl

# ---------------------------
# Node.js
# ---------------------------
node_modules/
**/node_modules/
npm-debug.log*
yarn-error.log*

# ---------------------------
# IDE & Editor Settings
# Keep shared settings, ignore user-specific
# ---------------------------
.idea/
*.swp
*.swo
*~
.spyderproject/
.spyproject/
.ropeproject/

# VS Code - keep shared config, ignore user secrets
# Note: settings.json is tracked but MUST NOT contain passwords
.vscode/*.log
.vscode/.ropeproject/

# ---------------------------
# Azure Emulator & Local Runtime Files
# ---------------------------
__azurite_db_blob*
__azurite_db_queue*
__azurite_db_table*
__blobstorage__/
__queuestorage__/
__tablestorage__/
azurite-debug.log

# ---------------------------
# Azure Data Studio
# ---------------------------
.azuredatastudio/

# ---------------------------
# Testing & Coverage
# ---------------------------
.pytest_cache/
.tox/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.pytype/
*.cover
*.log
nosetests.xml
coverage.xml
*.coveragexml

# ---------------------------
# Jupyter Notebook Checkpoints
# ---------------------------
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# ---------------------------
# Large Binary Artifacts
# These should be in Azure Artifacts, Blob Storage, or Git LFS
# ---------------------------
domains/spark/ArcGIS_GeoAnalyticsEngine/
*.jar
!**/src/**/*.jar

# ---------------------------
# dbt
# ---------------------------
tools/dbt/dbt-env/
target/
dbt_packages/
dbt_modules/
logs/

# ---------------------------
# Terraform / IaC State (if used)
# ---------------------------
*.tfstate
*.tfstate.*
.terraform/
*.tfvars
!*.tfvars.example

# ---------------------------
# OS Files
# ---------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ---------------------------
# Build Outputs
# ---------------------------
*.manifest
*.spec
docs/_build/

# ---------------------------
# Generated / Temporary
# ---------------------------
temp/
tmp/
*.tmp
*.completed.json
*.dev_OLD.json
runs/
cache/
retrieval/
containers/
stats/
# Load-test reports (tests/load/README.md) — keep baselines checked in
# under tests/load/baselines/ but do not commit raw runs.
reports/

# ---------------------------
# CodeQL Database (large, generated)
# ---------------------------
codeqlDB/

# ---------------------------
# Framework-specific
# ---------------------------
local_settings.py
db.sqlite3
db.sqlite3-journal
instance/
.webassets-cache
.scrapy

# ---------------------------
# Project Management
# ---------------------------
.pdm.toml
.pybuilder/

# ---------------------------
# AI / ML
# ---------------------------
.genaiscript
*.onnx
*.pkl
*.h5
*.pt
!**/models/README.md

# ---------------------------
# Claude Code — user-local state
# Shared instructions (rules/, context/, hooks/, settings.json) are tracked.
# Per-user memory and local overrides are not, and neither are the
# agents/commands/skills directories which Claude Code mirrors from the
# user's global ~/.claude install rather than the repo.
# ---------------------------
.claude/agent-memory/
.claude/agent-memory-local/
.claude/settings.local.json
.claude/agents/
.claude/commands/
.claude/skills/

# ---------------------------
# Bicep CLI binary (downloaded during CI lint; not a project artifact)
# ---------------------------
/bicep

# ---------------------------
# Stray VS Code Bicep extension installs under deploy/bicep/
# (Created by the azext-azureauth auto-install; not project dependencies.)
# ---------------------------
deploy/bicep/**/package.json
deploy/bicep/**/package-lock.json
deploy/bicep/**/node_modules/
.claude/worktrees/
