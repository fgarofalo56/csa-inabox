NEXT_PUBLIC_AZURE_AD_CLIENT_ID=your-client-id
NEXT_PUBLIC_AZURE_AD_TENANT_ID=your-tenant-id
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=CSA-in-a-Box Portal

# Toggle MSAL authentication. Set to "true" for any environment
# that must enforce auth (staging, preview, production). Leaving
# unset defaults to "false" (demo mode with no identity).
# Coordinated with backend ENVIRONMENT allow-list (CSA-0001/0019).
NEXT_PUBLIC_AUTH_ENABLED=false
