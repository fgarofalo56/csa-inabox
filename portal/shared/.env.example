# Entra ID (formerly Azure AD) — Pydantic Settings reads these exact names.
# Rename from AZURE_AD_* was CSA-0001: old names silently bypassed auth.
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-secret

# Environment / auth safety gate.
# ENVIRONMENT must be one of: local, demo, dev, qa, uat, test, preprod,
#   staging, production. Only "local" and "demo" allow AUTH_DISABLED=true.
# AUTH_DISABLED=true + ENVIRONMENT in {local, demo} yields a synthetic
#   Reader identity for local work; any other combination raises at
#   startup (see csa_platform/common/auth.py::enforce_auth_safety_gate).
ENVIRONMENT=local
AUTH_DISABLED=false
DEMO_MODE=false

DATABASE_URL=sqlite:///./portal.db
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=info
