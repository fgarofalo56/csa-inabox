{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "CSA-in-a-Box Source Registration API",
  "description": "Canonical JSON Schema for the source registration API types, merged from React and Svelte implementations.",
  "definitions": {
    "SourceType": {
      "type": "string",
      "enum": [
        "azure_sql",
        "synapse",
        "cosmos_db",
        "adls_gen2",
        "blob_storage",
        "databricks",
        "postgresql",
        "postgres",
        "mysql",
        "oracle",
        "sql_server",
        "rest_api",
        "odata",
        "sftp",
        "sharepoint",
        "event_hub",
        "iot_hub",
        "kafka",
        "file_drop",
        "s3",
        "snowflake",
        "dynamics365"
      ],
      "description": "Union of all supported data source types from both portal implementations."
    },
    "IngestionMode": {
      "type": "string",
      "enum": ["full", "incremental", "cdc", "streaming"]
    },
    "ClassificationLevel": {
      "type": "string",
      "enum": ["public", "internal", "confidential", "restricted", "cui", "fouo"]
    },
    "TargetFormat": {
      "type": "string",
      "enum": ["delta", "parquet", "csv", "json", "avro"]
    },
    "SourceStatus": {
      "type": "string",
      "enum": [
        "draft",
        "pending",
        "pending_approval",
        "approved",
        "provisioning",
        "active",
        "inactive",
        "paused",
        "decommissioned",
        "error",
        "archived"
      ],
      "description": "Superset of statuses from both implementations."
    },
    "ConnectionConfig": {
      "type": "object",
      "properties": {
        "host": { "type": "string" },
        "port": { "type": "integer" },
        "database": { "type": "string" },
        "schema_name": { "type": "string", "description": "Database schema (renamed from 'schema' to avoid keyword conflicts)." },
        "container": { "type": "string" },
        "path": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "api_url": { "type": "string", "format": "uri" },
        "auth_type": { "type": "string" },
        "authentication_method": { "type": "string" },
        "username": { "type": "string" },
        "password_secret": { "type": "string" },
        "connection_string_secret": { "type": "string" },
        "key_vault_secret_name": { "type": "string" },
        "event_hub_namespace": { "type": "string" },
        "consumer_group": { "type": "string" }
      },
      "additionalProperties": false
    },
    "ColumnDefinition": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "data_type": { "type": "string" },
        "nullable": { "type": "boolean" },
        "description": { "type": "string" },
        "is_pii": { "type": "boolean" },
        "is_primary_key": { "type": "boolean" },
        "classification": { "type": "string" }
      },
      "required": ["name", "data_type", "nullable"]
    },
    "SchemaDefinition": {
      "type": "object",
      "properties": {
        "columns": {
          "type": "array",
          "items": { "$ref": "#/definitions/ColumnDefinition" }
        },
        "tables": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "$ref": "#/definitions/ColumnDefinition" }
          }
        },
        "endpoints": {
          "type": "array",
          "items": { "type": "string" }
        },
        "auto_detect": { "type": "boolean" },
        "primary_key": {
          "type": "array",
          "items": { "type": "string" }
        },
        "partition_columns": {
          "type": "array",
          "items": { "type": "string" }
        },
        "watermark_column": { "type": "string" }
      },
      "additionalProperties": false
    },
    "IngestionConfig": {
      "type": "object",
      "properties": {
        "mode": { "$ref": "#/definitions/IngestionMode" },
        "schedule_cron": { "type": "string" },
        "batch_size": { "type": "integer", "minimum": 1 },
        "parallelism": { "type": "integer", "minimum": 1 },
        "max_retry_count": { "type": "integer" },
        "timeout_minutes": { "type": "integer" },
        "watermark_column": { "type": "string" }
      },
      "required": ["mode"]
    },
    "DataQualityRule": {
      "type": "object",
      "properties": {
        "rule_name": { "type": "string" },
        "rule_type": {
          "type": "string",
          "enum": ["not_null", "unique", "range", "regex", "custom_sql", "freshness", "completeness"]
        },
        "column": { "type": "string" },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        },
        "severity": {
          "type": "string",
          "enum": ["warning", "error", "critical"]
        }
      },
      "required": ["rule_name", "rule_type", "severity"]
    },
    "TargetConfig": {
      "type": "object",
      "properties": {
        "landing_zone": { "type": "string" },
        "container": { "type": "string" },
        "path_pattern": { "type": "string" },
        "format": { "$ref": "#/definitions/TargetFormat" },
        "partition_by": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["landing_zone", "container", "path_pattern", "format"]
    },
    "OwnerInfo": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "team": { "type": "string" },
        "domain": { "type": "string" },
        "cost_center": { "type": "string" }
      },
      "required": ["name", "email"]
    },
    "SourceRegistration": {
      "type": "object",
      "properties": {
        "source_name": { "type": "string" },
        "source_type": { "$ref": "#/definitions/SourceType" },
        "description": { "type": "string" },
        "domain": { "type": "string" },
        "classification": { "$ref": "#/definitions/ClassificationLevel" },
        "environment": { "type": "string" },
        "connection": { "$ref": "#/definitions/ConnectionConfig" },
        "schema_definition": { "$ref": "#/definitions/SchemaDefinition" },
        "ingestion": { "$ref": "#/definitions/IngestionConfig" },
        "quality_rules": {
          "type": "array",
          "items": { "$ref": "#/definitions/DataQualityRule" }
        },
        "target": { "$ref": "#/definitions/TargetConfig" },
        "owner": { "$ref": "#/definitions/OwnerInfo" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": [
        "source_name",
        "source_type",
        "connection",
        "ingestion",
        "classification",
        "owner",
        "target"
      ]
    },
    "SourceRecord": {
      "allOf": [
        { "$ref": "#/definitions/SourceRegistration" },
        {
          "type": "object",
          "properties": {
            "source_id": { "type": "string" },
            "status": { "$ref": "#/definitions/SourceStatus" },
            "created_at": { "type": "string", "format": "date-time" },
            "updated_at": { "type": "string", "format": "date-time" },
            "provisioned_at": { "type": "string", "format": "date-time" },
            "pipeline_id": { "type": "string" },
            "provisioning_details": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "required": ["source_id", "status", "created_at", "updated_at"]
        }
      ]
    },
    "PipelineRun": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "pipeline_id": { "type": "string" },
        "status": { "type": "string" },
        "started_at": { "type": "string", "format": "date-time" },
        "ended_at": { "type": "string", "format": "date-time" },
        "duration_seconds": { "type": "number" },
        "rows_read": { "type": "integer" },
        "rows_written": { "type": "integer" },
        "error_message": { "type": "string" },
        "errors": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["id", "pipeline_id", "status", "started_at"]
    },
    "RecentActivity": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["source_registered", "pipeline_run", "access_request", "product_published"]
        },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "title", "description", "timestamp"]
    },
    "ApiError": {
      "type": "object",
      "properties": {
        "detail": { "type": "string" },
        "status_code": { "type": "integer" }
      },
      "required": ["detail", "status_code"]
    },
    "PaginatedResponse": {
      "type": "object",
      "properties": {
        "items": { "type": "array" },
        "total": { "type": "integer" },
        "page": { "type": "integer" },
        "per_page": { "type": "integer" }
      },
      "required": ["items", "total", "page", "per_page"]
    }
  }
}
