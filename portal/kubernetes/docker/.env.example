# Backend — Entra ID (formerly Azure AD). Pydantic Settings reads these
# exact names (renamed from AZURE_AD_* per CSA-0001).
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
API_DATABASE_URL=sqlite:///./portal.db

# Environment / auth safety gate. ENVIRONMENT=local (default in
# docker-compose.yml) keeps the dev-mode demo identity active. Change to
# dev/qa/uat/test/preprod/staging/production will cause the backend to
# refuse to start without AZURE_TENANT_ID / AZURE_CLIENT_ID set.
ENVIRONMENT=local

# Frontend (MSAL reads its own NEXT_PUBLIC_* vars — see portal/react-webapp/.env.example)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Redis
REDIS_PASSWORD=change-me-to-a-strong-password
