{
  "name": "csa-portal-swa",
  "version": "1.0.0",
  "private": true,
  "description": "CSA-in-a-Box Data Onboarding Portal — Azure Static Web Apps",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "swa:start": "npx @azure/static-web-apps-cli start http://localhost:5173 --api-location api",
    "swa:deploy": "npx @azure/static-web-apps-cli deploy --app-location build --api-location api"
  },
  "dependencies": {
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.5.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@azure/static-web-apps-cli": "^2.0.0",
    "@sveltejs/adapter-azure-swa": "^0.22.0",
    "@types/node": "^20.11.0",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.3.3",
    "vite": "^6.0.0"
  }
}
