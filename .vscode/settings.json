      "name": "alz-postgresql-srv01-westus",
      "group": "Limitless Data",
      "database": "vectordb",
      "username": "jarvis"
    },
    {
      "previewLimit": 50,
      "server": "192.168.10.201",
      "port": 5433,
      "driver": "PostgreSQL",
      "database": "postgres",
      "username": "postgres",
      "name": "local_PostgresSQL",
      "askForPassword": true
    }
  ],
  "dbcode.connections": [
    {
      "connectionId": "SZhep_7GqqoDoCpInbd1b",
      "name": "local_PostgreSQL",
      "driver": "postgres",
      "connectionType": "host",
      "host": "192.168.10.201",
      "port": 5433,
      "ssl": false,
      "username": "postgres",
      "password": "",
      "savePassword": "secretStorage",
      "database": "postgres",
      "readOnly": false,
      "connectionTimeout": 30
    }
  ],
  "chat.mcp.discovery.enabled": {
    "claude-desktop": false,
    "windsurf": false,
    "cursor-global": false,
    "cursor-workspace": false
  }
}
