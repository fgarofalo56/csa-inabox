{
  "expectation_suite_name": "silver_sales_orders_suite",
  "ge_cloud_id": null,
  "data_asset_type": null,
  "meta": {
    "great_expectations_version": "0.18.0",
    "citations": [
      {
        "citation_date": "2026-04-14",
        "comment": "Suite for validating conformed sales orders in the Silver layer after dbt Silver model materialisation."
      }
    ]
  },
  "expectations": [
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {
        "column": "order_id"
      },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "order_id"
      },
      "meta": {
        "notes": "Primary key — must never be null."
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_unique",
      "kwargs": {
        "column": "order_id"
      },
      "meta": {
        "notes": "Primary key — must be unique after dedup in Silver."
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "customer_id"
      },
      "meta": {
        "notes": "Foreign key to customers must be present."
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "product_id"
      },
      "meta": {
        "notes": "Foreign key to products must be present."
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "quantity",
        "min_value": 1,
        "mostly": 0.99
      },
      "meta": {
        "notes": "Quantity should be positive for valid orders."
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "unit_price",
        "min_value": 0.0,
        "mostly": 0.99
      },
      "meta": {
        "notes": "Unit price should be non-negative."
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "line_total",
        "min_value": 0.0,
        "mostly": 0.99
      },
      "meta": {
        "notes": "Computed line total should be non-negative."
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "order_date"
      },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "sales_region"
      },
      "meta": {
        "notes": "Sales region must be populated in Silver (dbt test enforces this)."
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "sales_channel"
      },
      "meta": {
        "notes": "Sales channel must be populated in Silver."
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "is_valid"
      },
      "meta": {
        "notes": "Quality flag must always be computed."
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "is_valid",
        "value_set": [true, false]
      },
      "meta": {}
    },
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {
        "min_value": 1
      },
      "meta": {
        "notes": "Silver orders table must not be empty."
      }
    },
    {
      "expectation_type": "expect_column_proportion_of_unique_values_to_be_between",
      "kwargs": {
        "column": "order_id",
        "min_value": 0.99
      },
      "meta": {
        "notes": "Near-100% uniqueness confirms dedup in Silver."
      }
    }
  ]
}
