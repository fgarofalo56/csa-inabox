{
  "_comment": "OpenLineage configuration for Databricks clusters. Apply via cluster Spark config or init script. This sends lineage metadata to the Purview OpenLineage endpoint for automatic data flow tracking.",
  "transport": {
    "type": "http",
    "url": "https://${PURVIEW_ACCOUNT_NAME}.purview.azure.com",
    "endpoint": "/api/atlas/v2/entity",
    "auth": {
      "type": "oauth",
      "grant_type": "client_credentials",
      "client_id": "${AZURE_CLIENT_ID}",
      "token_url": "${AZURE_TOKEN_URL}",
      "scope": "${PURVIEW_SCOPE}"
    }
  },
  "facets": {
    "spark": {
      "disabled": ["spark.logicalPlan"]
    }
  },
  "sparkConfig": {
    "spark.openlineage.transport.type": "http",
    "spark.openlineage.transport.url": "https://${PURVIEW_ACCOUNT_NAME}.purview.azure.com",
    "spark.openlineage.namespace": "csa-inabox-databricks",
    "spark.extraListeners": "io.openlineage.spark.agent.OpenLineageSparkListener"
  }
}
