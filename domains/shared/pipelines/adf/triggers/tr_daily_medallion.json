{
  "name": "tr_daily_medallion",
  "properties": {
    "description": "Triggers the medallion orchestration pipeline daily at 06:00 UTC. Runs the full Bronze -> Silver -> Gold pipeline sequence with dbt tests.",
    "annotations": [
      "csa-inabox",
      "scheduled",
      "medallion"
    ],
    "type": "ScheduleTrigger",
    "typeProperties": {
      "recurrence": {
        "frequency": "Day",
        "interval": 1,
        "startTime": "2026-01-01T06:00:00Z",
        "timeZone": "UTC",
        "schedule": {
          "hours": [6],
          "minutes": [0]
        }
      }
    },
    "pipelines": [
      {
        "pipelineReference": {
          "referenceName": "pl_medallion_orchestration",
          "type": "PipelineReference"
        },
        "parameters": {
          "environment": "prod",
          "fullRefresh": false,
          "alertWebhookUrl": ""
        }
      }
    ]
  }
}
