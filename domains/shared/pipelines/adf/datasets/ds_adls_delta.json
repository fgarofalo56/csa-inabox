{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "metadata": {
        "description": "ADF Dataset: Parameterized Delta Lake on ADLS Gen2",
        "pattern": "dataset"
    },
    "resources": [
        {
            "type": "Microsoft.DataFactory/factories/datasets",
            "apiVersion": "2018-06-01",
            "name": "[concat(parameters('factoryName'), '/ds_adls_delta')]",
            "properties": {
                "description": "Parameterized Delta Lake dataset for Silver/Gold layer reads. Uses Databricks Delta connector.",
                "type": "Parquet",
                "linkedServiceName": {
                    "referenceName": "ls_adls_gen2",
                    "type": "LinkedServiceReference"
                },
                "typeProperties": {
                    "location": {
                        "type": "AzureBlobFSLocation",
                        "fileSystem": {
                            "value": "@dataset().containerName",
                            "type": "Expression"
                        },
                        "folderPath": {
                            "value": "@dataset().folderPath",
                            "type": "Expression"
                        }
                    }
                },
                "parameters": {
                    "containerName": {
                        "type": "String",
                        "defaultValue": "curated"
                    },
                    "folderPath": {
                        "type": "String"
                    }
                },
                "schema": [],
                "annotations": [
                    "delta-lake",
                    "silver-gold-layer",
                    "parameterized",
                    "csa-inabox"
                ]
            }
        }
    ],
    "parameters": {
        "factoryName": {
            "type": "string"
        }
    }
}
