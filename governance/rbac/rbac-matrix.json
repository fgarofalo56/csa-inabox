{
    "description": "RBAC matrix for CSA-in-a-Box data platform. Maps personas to Azure role assignments across services.",
    "version": "1.0.0",
    "personas": {
        "PlatformAdmin": {
            "description": "Full platform administration - infrastructure, networking, security",
            "assignments": [
                { "scope": "rg/platform-dlz", "role": "Contributor" },
                { "scope": "rg/platform-dmlz", "role": "Contributor" },
                { "scope": "rg/databricks", "role": "Contributor" },
                { "scope": "rg/storage", "role": "Storage Blob Data Owner" },
                { "scope": "rg/keyvault", "role": "Key Vault Administrator" },
                { "scope": "rg/synapse", "role": "Synapse Administrator" },
                { "scope": "rg/purview", "role": "Purview Data Source Administrator" },
                { "scope": "rg/adf", "role": "Data Factory Contributor" }
            ]
        },
        "DataEngineer": {
            "description": "Build and maintain data pipelines, dbt models, ADF pipelines",
            "assignments": [
                { "scope": "rg/databricks", "role": "Contributor" },
                { "scope": "rg/storage", "role": "Storage Blob Data Contributor" },
                { "scope": "rg/adf", "role": "Data Factory Contributor" },
                { "scope": "rg/synapse", "role": "Synapse SQL Administrator" },
                { "scope": "rg/keyvault", "role": "Key Vault Secrets User" },
                { "scope": "rg/eventhubs", "role": "Azure Event Hubs Data Receiver" },
                { "scope": "rg/cosmos", "role": "Cosmos DB Operator" }
            ]
        },
        "DataScientist": {
            "description": "Build ML models, access curated data, run experiments",
            "assignments": [
                { "scope": "rg/databricks", "role": "Contributor" },
                { "scope": "rg/storage", "role": "Storage Blob Data Reader" },
                { "scope": "rg/ml", "role": "AzureML Compute Operator" },
                { "scope": "rg/ml", "role": "AzureML Data Scientist" },
                { "scope": "rg/keyvault", "role": "Key Vault Secrets User" }
            ]
        },
        "DomainOwner": {
            "description": "Business domain ownership - manages domain data products and quality",
            "assignments": [
                { "scope": "rg/storage", "role": "Storage Blob Data Reader" },
                { "scope": "rg/purview", "role": "Purview Data Reader" },
                { "scope": "rg/databricks", "role": "Reader" },
                { "scope": "rg/synapse", "role": "Synapse User" }
            ]
        },
        "Analyst": {
            "description": "Consume gold-layer data products for reporting and analysis",
            "assignments": [
                { "scope": "rg/storage", "role": "Storage Blob Data Reader" },
                { "scope": "rg/synapse", "role": "Synapse User" },
                { "scope": "rg/databricks", "role": "Reader" },
                { "scope": "rg/purview", "role": "Purview Data Reader" }
            ]
        },
        "GovernanceOfficer": {
            "description": "Data governance, classification, compliance oversight",
            "assignments": [
                { "scope": "rg/purview", "role": "Purview Data Curator" },
                { "scope": "rg/purview", "role": "Purview Data Source Administrator" },
                { "scope": "rg/storage", "role": "Storage Blob Data Reader" },
                { "scope": "rg/keyvault", "role": "Key Vault Reader" }
            ]
        },
        "CICDServicePrincipal": {
            "description": "GitHub Actions OIDC identity for automated deployments",
            "assignments": [
                { "scope": "rg/cicd-dlz", "role": "Contributor" },
                { "scope": "rg/cicd-dmlz", "role": "Contributor" },
                { "scope": "subscription/connectivity", "role": "Reader" },
                { "scope": "subscription/management", "role": "Reader" }
            ]
        }
    },
