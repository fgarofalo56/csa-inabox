{
    "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "purviewAccountName": {
            "type": "String"
        },
        "location": {
            "type": "String"
        },
        "eventHubSubscriptionId": {
            "type": "String",
            "metadata": {
                "description": "Subscription ID where the Event Hub namespace resides."
            }
        },
        "eventHubResourceGroup": {
            "type": "String",
            "metadata": {
                "description": "Resource group name for the Event Hub namespace."
            }
        },
        "eventHubNamespaceName": {
            "type": "String",
            "defaultValue": "dmz-eventhub-dev",
            "metadata": {
                "description": "Name of the Event Hub namespace."
            }
        },
        "notificationEventHubName": {
            "type": "String",
            "defaultValue": "dms-purview-eh-dev",
            "metadata": {
                "description": "Name of the notification Event Hub."
            }
        },
        "hookEventHubName": {
            "type": "String",
            "defaultValue": "dmz-purview-hooks",
            "metadata": {
                "description": "Name of the hook Event Hub."
            }
        }
    },
    "variables": {},
    "resources": [
        {
            "type": "Microsoft.Purview/accounts",
            "apiVersion": "2021-07-01",
            "name": "[parameters('purviewAccountName')]",
            "location": "[parameters('location')]",
            "dependsOn": [],
            "tags": {},
            "sku": {
                "name": "Standard",
                "capacity": 1
            },
            "identity": {
                "type": "SystemAssigned"
            },
            "properties": {
                "publicNetworkAccess": "Disabled",
                "managedResourcesPublicNetworkAccess": "Disabled",
                "managedResourceGroupName": "[concat('managed-rg-',parameters('purviewAccountName'))]"
            }
        },
        {
            "type": "Microsoft.Resources/deployments",
            "apiVersion": "2019-05-01",
            "name": "Role-dmz-eventhub-de-c9b01336-34d2-4de9-92d2-b167c6d8b049",
            "dependsOn": [
                "[concat('Microsoft.Purview/accounts/', parameters('purviewAccountName'))]"
            ],
            "properties": {
                "mode": "Incremental",
                "parameters": {},
                "template": {
                    "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
                    "contentVersion": "1.0.0.0",
                    "parameters": {},
                    "variables": {},
                    "resources": [
                        {
                            "apiVersion": "2018-09-01-preview",
                            "name": "c9b01336-34d2-4de9-92d2-b167c6d8b049",
                            "type": "Microsoft.Authorization/roleAssignments",
                            "scope": "[concat('/subscriptions/', parameters('eventHubSubscriptionId'), '/resourceGroups/', parameters('eventHubResourceGroup'), '/providers/Microsoft.EventHub/namespaces/', parameters('eventHubNamespaceName'), '/eventhubs/', parameters('notificationEventHubName'))]",
                            "properties": {
                                "principalId": "[reference(parameters('purviewAccountName'), '2021-07-01', 'Full').identity.principalId]",
                                "principalType": "ServicePrincipal",
                                "roleDefinitionId": "[resourceId('Microsoft.Authorization/roleDefinitions', '2b629674-e913-4c01-ae53-ef4638d8f975')]"
                            }
                        }
                    ],
                    "outputs": {}
                }
            },
            "resources": [],
            "subscriptionId": "[parameters('eventHubSubscriptionId')]",
            "resourceGroup": "[parameters('eventHubResourceGroup')]"
        },
        {
            "type": "Microsoft.Purview/accounts/kafkaConfigurations",
            "apiVersion": "2021-07-01",
            "name": "[concat(parameters('purviewAccountName'), '/', 'purview-notifications')]",
            "dependsOn": [
                "Role-dmz-eventhub-de-c9b01336-34d2-4de9-92d2-b167c6d8b049"
            ],
            "properties": {
                "credentials": {
                    "type": "SystemAssigned"
                },
                "eventHubResourceId": "[concat('/subscriptions/', parameters('eventHubSubscriptionId'), '/resourceGroups/', parameters('eventHubResourceGroup'), '/providers/Microsoft.EventHub/namespaces/', parameters('eventHubNamespaceName'), '/eventhubs/', parameters('notificationEventHubName'))]",
                "eventHubType": "Notification",
                "eventStreamingState": "Enabled",
                "eventStreamingType": "Azure"
            }
        },
        {
            "type": "Microsoft.Resources/deployments",
            "apiVersion": "2019-05-01",
            "name": "Role-dmz-eventhub-de-c9b01336-34d2-4de9-92d2-b167c6d8b04a",
            "dependsOn": [
                "[concat('Microsoft.Purview/accounts/', parameters('purviewAccountName'))]"
            ],
            "properties": {
                "mode": "Incremental",
                "parameters": {},
                "template": {
                    "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
                    "contentVersion": "1.0.0.0",
                    "parameters": {},
                    "variables": {},
                    "resources": [
                        {
                            "apiVersion": "2018-09-01-preview",
                            "name": "c9b01336-34d2-4de9-92d2-b167c6d8b04a",
                            "type": "Microsoft.Authorization/roleAssignments",
                            "scope": "[concat('/subscriptions/', parameters('eventHubSubscriptionId'), '/resourceGroups/', parameters('eventHubResourceGroup'), '/providers/Microsoft.EventHub/namespaces/', parameters('eventHubNamespaceName'), '/eventhubs/', parameters('hookEventHubName'))]",
                            "properties": {
                                "principalId": "[reference(parameters('purviewAccountName'), '2021-07-01', 'Full').identity.principalId]",
                                "principalType": "ServicePrincipal",
                                "roleDefinitionId": "[resourceId('Microsoft.Authorization/roleDefinitions', 'a638d3c7-ab3a-418d-83e6-5f17a39d4fde')]"
                            }
                        }
                    ],
                    "outputs": {}
                }
            },
            "resources": [],
            "subscriptionId": "[parameters('eventHubSubscriptionId')]",
            "resourceGroup": "[parameters('eventHubResourceGroup')]"
        },
        {
            "type": "Microsoft.Purview/accounts/kafkaConfigurations",
            "apiVersion": "2021-07-01",
            "name": "[concat(parameters('purviewAccountName'), '/', 'purview-hooks')]",
            "dependsOn": [
                "Role-dmz-eventhub-de-c9b01336-34d2-4de9-92d2-b167c6d8b04a"
            ],
            "properties": {
                "credentials": {
                    "type": "SystemAssigned"
                },
                "eventHubResourceId": "[concat('/subscriptions/', parameters('eventHubSubscriptionId'), '/resourceGroups/', parameters('eventHubResourceGroup'), '/providers/Microsoft.EventHub/namespaces/', parameters('eventHubNamespaceName'), '/eventhubs/', parameters('hookEventHubName'))]",
                "eventHubType": "Hook",
                "eventStreamingState": "Enabled",
                "eventStreamingType": "Azure",
                "consumerGroup": "$Default"
            }
        }
    ],
    "outputs": {}
}