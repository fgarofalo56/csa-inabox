# =============================================================================
# CSA-in-a-Box: Terraform Root Version Constraints
# Mirrors the Bicep IaC at deploy/bicep/ for DLZ and DMLZ landing zones.
# =============================================================================

terraform {
  required_version = ">= 1.6.0"

  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = "~> 4.0"
    }
    azuread = {
      source  = "hashicorp/azuread"
      version = "~> 3.0"
    }
    random = {
      source  = "hashicorp/random"
      version = "~> 3.6"
    }
  }
}
