# =============================================================================
# Terraform Backend Configuration — Azure Storage
# =============================================================================
# Copy this file to backend.hcl and fill in your values, then initialise:
#
#   terraform init -backend-config=backend.hcl
#
# For DLZ:
#   cd deploy/terraform/dlz && terraform init -backend-config=../backend.hcl
#
# For DMLZ:
#   cd deploy/terraform/dmlz && terraform init -backend-config=../backend.hcl

resource_group_name  = "rg-terraform-state"
storage_account_name = "stterraformstate"
container_name       = "tfstate"
key                  = "csa-inabox/dlz/terraform.tfstate"
