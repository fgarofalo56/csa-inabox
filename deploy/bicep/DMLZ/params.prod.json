{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "location": {
            "value": "East US"
        },
        "environment": {
            "value": "prod"
        },
        "prefix": {
            "value": "dmlz"
        },
        "logAnalyticsWorkspaceId": {
            "value": "<LOG_ANALYTICS_WORKSPACE_RESOURCE_ID>"
        },
        "deployModules": {
            "value": {
                "governance": true,
                "databricks": true
            }
        },
        "privateDNSZones": {
            "value": {
                "subscriptionId": "<CONNECTIVITY_SUBSCRIPTION_ID>",
                "resourceGroupName": "rg-connectivity-dns-eastus"
            }
        },
        "parGovernance": {
            "value": {
                "parLocation": "eastus",
                "parPurviewName": "dmlz-prod-purview",
                "parPurviewSku": {
                    "name": "Standard",
                    "capacity": 4
                },
                "parTenantEndpointState": "Disabled",
                "parPurviewPublicNetworkAccess": "Disabled",
                "parPurviewKafkaConfig": true,
                "rgTags": {
                    "Service": "Governance"
                },
                "tags": {
                    "Owner": "Platform Team",
                    "CloudScale": "DMLZ",
                    "Domain": "Data Management",
                    "Contact": "<CONTACT_EMAIL>",
                    "Project": "CSA-in-a-Box",
                    "Environment": "prod",
                    "Toolkit": "bicep"
                }
            }
        },
        "parDatabricks": {
            "value": {
                "workspaceName": "dmlz-prod-dbw-gov",
                "vnetId": "<DMLZ_VNET_RESOURCE_ID>",
                "publicSubnetName": "databricks-gov-public",
                "privateSubnetName": "databricks-gov-private",
                "privateEndpointSubnets": [
                    {
                        "subscriptionId": "<DMLZ_SUBSCRIPTION_ID>",
                        "vNetResourceGroup": "rg-dmlz-prod-network-eastus",
                        "vNetName": "vnet-dmlz-prod-eastus",
                        "subnetName": "snet-private-endpoints",
                        "vNetLocation": "eastus"
                    }
                ],
                "privateDnsZoneId": "<DATABRICKS_PRIVATE_DNS_ZONE_ID>"
            }
        }
    }
}
