{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "location": {
            "value": "<AZURE_REGION>"
        },
        "environment": {
            "value": "<ENVIRONMENT_NAME>"
        },
        "prefix": {
            "value": "dmlz"
        },
        "logAnalyticsWorkspaceId": {
            "value": "<LOG_ANALYTICS_WORKSPACE_RESOURCE_ID>"
        },
        "deployModules": {
            "value": {
                "governance": true,
                "databricks": true
            }
        },
        "privateDNSZones": {
            "value": {
                "subscriptionId": "<CONNECTIVITY_SUBSCRIPTION_ID>",
                "resourceGroupName": "<DNS_RESOURCE_GROUP_NAME>"
            }
        },
        "parGovernance": {
            "value": {
                "parLocation": "<AZURE_REGION>",
                "parPurviewName": "<PURVIEW_ACCOUNT_NAME>",
                "parPurviewSku": {
                    "name": "Standard",
                    "capacity": 1
                },
                "parTenantEndpointState": "Disabled",
                "parPurviewPublicNetworkAccess": "Disabled",
                "parPurviewKafkaConfig": false,
                "rgTags": {},
                "tags": {
                    "Owner": "<TEAM_NAME>",
                    "CloudScale": "DMLZ",
                    "Domain": "Data Management",
                    "Contact": "<CONTACT_EMAIL>",
                    "Project": "<PROJECT_NAME>",
                    "Environment": "<ENVIRONMENT_NAME>",
                    "Toolkit": "bicep"
                }
            }
        },
        "parDatabricks": {
            "value": {
                "workspaceName": "<DATABRICKS_GOV_WORKSPACE_NAME>",
                "vnetId": "<DMLZ_VNET_RESOURCE_ID>",
                "publicSubnetName": "databricks-gov-public",
                "privateSubnetName": "databricks-gov-private",
                "privateEndpointSubnets": [
                    {
                        "subscriptionId": "<DMLZ_SUBSCRIPTION_ID>",
                        "vNetResourceGroup": "<VNET_RESOURCE_GROUP>",
                        "vNetName": "<DMLZ_VNET_NAME>",
                        "subnetName": "<PRIVATE_ENDPOINT_SUBNET>",
                        "vNetLocation": "<AZURE_REGION>"
                    }
                ],
                "privateDnsZoneId": "<DATABRICKS_PRIVATE_DNS_ZONE_ID>"
            }
        }
    }
}
