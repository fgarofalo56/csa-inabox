{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "location": {
            "value": "East US 2"
        },
        "environment": {
            "value": "dev"
        },
        "prefix": {
            "value": "dlz"
        },
        "deployModules": {
            "value": {
                "cosmosDB": true,
                "storageZones": true,
                "externalStorage": true,
                "synapse": false,
                "functions": false,
                "streamAnalytics": false,
                "appInsights": false,
                "privateEndpoints": false,
                "genericStorage": false,
                "selfHostedIR": false
            }
        },
        "privateDNSZones": {
            "value": {
                "subscriptionId": "<SUBSCRIPTION_ID>",
                "resourceGroupName": "rg-alz-dev-dns-eastus"
            }
        },
        "parCosmosDB": {
            "value": {
                "cosmosDbAccountName": "DataHiveCosmosSQL",
                "enableAutomaticFailover": false,
                "defaultDatabaseName": "default",
                "enableMultipleWriteLocations": false,
                "enableAnalyticalStorage": false,
                "enableFreeTier": false,
                "enableBurstCapacity": false,
                "enableMaterializedViews": false,
                "enableCassandraConnector": false,
                "enablePartitionMerge": false,
                "enablePerRegionPerPartitionAutoscale": false,
                "enablePriorityBasedExecution": false,
                "disableKeyBasedMetadataWriteAccess": false,
                "disableLocalAuth": true,
                "consistencyLevel": "Session",
                "backupPolicyType": "Continuous",
                "backupIntervalInMinutes": 240,
                "backupRetentionInHours": 720,
                "continuousBackupTier": "Continuous7Days",
                "publicNetworkAccess": "Disabled",
                "networkAclBypass": "None",
                "ipRules": [],
                "virtualNetworkRules": [],
                "tags": {
                    "DLZ Type": "No SQL",
                    "API": "SQL"
                }
            }
        },
        "parStorage": {
            "value": {
                "storageAccountName": "dlzstorage",
                "sku": "Standard_LRS",
                "kind": "StorageV2",
                "domainFileSystemNames": [
                    "data",
                    "di001",
                    "di002"
                ],
                "dataProductFileSystemNames": [
                    "data",
                    "di001",
                    "di002"
                ],
                "privateEndpointSubnets": [
                    {
                        "subscriptionId": "<SUBSCRIPTION_ID>",
                        "vNetResourceGroup": "rg-alz-dev-spokeVnet-eastus2",
                        "vNetName": "alz-dev-spokeVnet-eastus2",
                        "subnetName": "privatelinke",
                        "vNetLocation": "East US 2"
                    }
                ],
                "virtualNetworkRules": [],
                "tags": {
                    "DLZ Type": "Storage",
                    "Purpose": "Shared Storage zones"
                }
            }
        },
        "parExternalStorage": {
            "value": {
                "storageAccountName": "dlzstorage",
                "sku": "Standard_LRS",
                "kind": "StorageV2",
                "fileSytemNames": [
                    "data"
                ],
                "privateEndpointSubnets": [
                    {
                        "subscriptionId": "<SUBSCRIPTION_ID>",
                        "vNetResourceGroup": "rg-alz-dev-spokeVnet-eastus2",
                        "vNetName": "alz-dev-spokeVnet-eastus2",
                        "subnetName": "privatelinke",
                        "vNetLocation": "East US 2"
                    }
                ],
                "virtualNetworkRules": [],
                "tags": {
                    "DLZ Type": "External Storage",
                    "Purpose": "External Shared Storage"
                }
            }
        },
        "parSynapse": {
            "value": {
                "synapseWorkspaceName": "dlzsynapse",
                "sqlPoolName": "dlzsqlpool",
                "managedVirtualNetworkName": "dlzManagedVnet",
                "managedPrivateEndpointName": "dlzManagedPrivateEndpoint",
                "managedPrivateEndpointDescription": "DLZ Synapse Managed Private Endpoint",
                "managedPrivateEndpointGroupName": "dlzManagedPrivateEndpointGroup",
                "managedPrivateEndpointGroupDescription": "DLZ Synapse Managed Private Endpoint Group",
                "privateLinkHubName": "dlzPrivateLinkHub",
                "privateLinkHubDescription": "DLZ Synapse Private Link Hub",
                "privateLinkHubLocation": "[parameters('location')]",
                "tags": {
                    "DLZ Type": "Synapse"
                }
            }
        }
    }
}