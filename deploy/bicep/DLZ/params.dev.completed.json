{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "location": {
            "value": "East US"
        },
        "environment": {
            "value": "dev"
        },
        "prefix": {
            "value": "dlz"
        },
        "logAnalyticsWorkspaceId": {
            "value": "<LOG_ANALYTICS_WORKSPACE_RESOURCE_ID>"
        },
        "deployModules": {
            "value": {
                "cosmosDB": false,
                "storageZones": true,
                "externalStorage": true,
                "synapse": false,
                "databricks": true,
                "dataFactory": true,
                "eventHubs": false,
                "dataExplorer": false,
                "machineLearning": false
            }
        },
        "privateDNSZones": {
            "value": {
                "subscriptionId": "<CONNECTIVITY_SUBSCRIPTION_ID>",
                "resourceGroupName": "rg-connectivity-dns-eastus"
            }
        },
        "parCosmosDB": {
            "value": {
                "cosmosDbAccountName": "cosmos",
                "enableAutomaticFailover": "Disabled",
                "defaultDatabaseName": "default",
                "enableMultipleWriteLocations": "Disabled",
                "enableAnalyticalStorage": "Disabled",
                "enableFreeTier": true,
                "enableMaterializedViews": false,
                "enableBurstCapacity": true,
                "enableCassandraConnector": false,
                "enablePartitionMerge": false,
                "enablePerRegionPerPartitionAutoscale": false,
                "enablePriorityBasedExecution": false,
                "disableKeyBasedMetadataWriteAccess": false,
                "disableLocalAuth": true,
                "consistencyLevel": "Session",
                "backupPolicyType": "Continuous",
                "backupIntervalInMinutes": 240,
                "backupRetentionInHours": 8,
                "continuousBackupTier": "Continuous7Days",
                "publicNetworkAccess": "Disabled",
                "networkAclBypass": "None",
                "ipRules": [],
                "virtualNetworkRules": [],
                "tags": {
                    "Service": "CosmosDB"
                }
            }
        },
        "parStorage": {
            "value": {
                "storageAccountName": "csadlzdevst",
                "sku": "Standard_LRS",
                "kind": "StorageV2",
                "domainFileSystemNames": [
                    "raw",
                    "bronze",
                    "silver",
                    "gold",
                    "curated",
                    "enriched"
                ],
                "dataProductFileSystemNames": [
                    "data",
                    "workspace",
                    "synapse"
                ],
                "privateEndpointSubnets": [
                    {
                        "subscriptionId": "<DLZ_SUBSCRIPTION_ID>",
                        "vNetResourceGroup": "rg-dlz-dev-network-eastus",
                        "vNetName": "vnet-dlz-dev-eastus",
                        "subnetName": "snet-private-endpoints",
                        "vNetLocation": "eastus"
                    }
                ],
                "virtualNetworkRules": [],
                "tags": {
                    "Service": "Storage",
                    "DataClassification": "internal"
                }
            }
        },
        "parExternalStorage": {
            "value": {
                "storageAccountName": "csadlzdevextst",
                "sku": "Standard_LRS",
                "kind": "StorageV2",
                "fileSytemNames": [
                    "inbox",
                    "outbox"
                ],
                "privateEndpointSubnets": [
                    {
                        "subscriptionId": "<DLZ_SUBSCRIPTION_ID>",
                        "vNetResourceGroup": "rg-dlz-dev-network-eastus",
                        "vNetName": "vnet-dlz-dev-eastus",
                        "subnetName": "snet-private-endpoints",
                        "vNetLocation": "eastus"
                    }
                ],
                "virtualNetworkRules": [],
                "tags": {
                    "Service": "ExternalStorage"
                }
            }
        },
        "parSynapse": {
            "value": {
                "synapseWorkspaceName": "dlz-dev-synapse",
                "sqlAdminUsername": "sqladmin",
                "sqlAdminPassword": "<SQL_ADMIN_PASSWORD>",
                "tags": {
                    "Service": "Synapse"
                }
            }
        },
        "parDatabricks": {
            "value": {
                "workspaceName": "dlz-dev-dbw",
                "pricingTier": "premium",
                "enableNoPublicIp": true,
                "vnetId": "<SPOKE_VNET_RESOURCE_ID>",
                "publicSubnetName": "databricks-public",
                "privateSubnetName": "databricks-private",
                "privateEndpointSubnets": [
                    {
                        "subscriptionId": "<DLZ_SUBSCRIPTION_ID>",
                        "vNetResourceGroup": "rg-dlz-dev-network-eastus",
                        "vNetName": "vnet-dlz-dev-eastus",
                        "subnetName": "snet-private-endpoints",
                        "vNetLocation": "eastus"
                    }
                ],
                "privateDnsZoneId": "<DATABRICKS_PRIVATE_DNS_ZONE_ID>"
            }
        },
        "parDataFactory": {
            "value": {
                "factoryName": "dlz-dev-adf",
                "managedVirtualNetworkEnabled": true,
                "privateEndpointSubnets": [
                    {
                        "subscriptionId": "<DLZ_SUBSCRIPTION_ID>",
                        "vNetResourceGroup": "rg-dlz-dev-network-eastus",
                        "vNetName": "vnet-dlz-dev-eastus",
                        "subnetName": "snet-private-endpoints",
                        "vNetLocation": "eastus"
                    }
                ],
                "privateDnsZoneIdDataFactory": "<ADF_PRIVATE_DNS_ZONE_ID>",
                "privateDnsZoneIdPortal": "<ADF_PORTAL_PRIVATE_DNS_ZONE_ID>"
            }
        },
        "parEventHubs": {
            "value": {
                "namespaceName": "dlz-dev-ehns",
                "sku": "Standard",
                "eventHubs": [
                    {
                        "name": "ingestion",
                        "partitionCount": 2,
                        "messageRetentionInDays": 1
                    }
                ],
                "privateEndpointSubnets": [],
                "privateDnsZoneId": ""
            }
        },
        "parMachineLearning": {
            "value": {
                "workspaceName": "dlz-dev-ml",
                "storageAccountId": "",
                "keyVaultId": "",
                "applicationInsightsId": "",
                "privateEndpointSubnets": []
            }
        },
        "parDataExplorer": {
            "value": {
                "clusterName": "dlzdevadx",
                "skuName": "Dev(No SLA)_Standard_E2a_v4",
                "skuCapacity": 1,
                "databases": [
                    {
                        "name": "analytics",
                        "softDeletePeriod": "P30D",
                        "hotCachePeriod": "P7D"
                    }
                ],
                "privateEndpointSubnets": [],
                "privateDnsZoneId": ""
            }
        },
        "parStreamAnalytics": {
            "value": {
                "jobName": "dlz-dev-asa",
                "streamingUnits": 1
            }
        },
        "parFunctions": {
            "value": {
                "functionAppName": "dlz-dev-func",
                "runtime": "python",
                "planSku": "Y1"
            }
        }
    }
}
